function NexoUI:Notify(opts)
	opts = opts or {}
	local style = NOTIFY_STYLES[opts.Type or "Info"] or NOTIFY_STYLES.Info
	local title = opts.Title or "Notification"
	local content = opts.Content or ""
	local duration = opts.Duration or 4
	-- BUGFIX: allow Notify() before CreateWindow() by lazily building a holder
	if not self._notifyHolder then
		local _sg = getScreenGui()
		self._notifyHolder = new("Frame", {
			Name = "Notifications", AnchorPoint = Vector2.new(1,0),
			Position = UDim2.new(1, -16, 0, 16), Size = UDim2.new(0, 280, 1, -32),
			BackgroundTransparency = 1, ZIndex = 50, Parent = _sg,
		})
		vlist(self._notifyHolder, 10, Enum.HorizontalAlignment.Right)
	end

	local card = new("Frame", {
		Size = UDim2.new(1, 0, 0, 56),
		BackgroundColor3 = Color3.fromRGB(0, 0, 0),
		BackgroundTransparency = 1,
		ClipsDescendants = true,
		ZIndex = 51,
		Parent = self._notifyHolder,
	})
	corner(10, card)
	-- animated galaxy starfield background inside the notification
	createStarfield(card, 26, 52, 10)
	-- white border with an animated laser sweep
	local laser = new("UIStroke", {
		Color = Color3.fromRGB(255, 255, 255),
		Thickness = 1.5,
		Transparency = 1,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		Parent = card,
	})
	local laserGrad = new("UIGradient", {
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(60, 60, 80)),
			ColorSequenceKeypoint.new(0.42, Color3.fromRGB(150, 150, 180)),
			ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
			ColorSequenceKeypoint.new(0.58, Color3.fromRGB(150, 150, 180)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(60, 60, 80)),
		}),
		Parent = laser,
	})
	local sweep = 0
	local laserConn
	laserConn = RunService.RenderStepped:Connect(function(dt)
		if not card.Parent then laserConn:Disconnect() return end
		sweep = (sweep + dt * 0.7) % 1
		laserGrad.Offset = Vector2.new(sweep * 2 - 1, 0)
	end)

	local badge = new("Frame", {
		Position = UDim2.new(0, 12, 0.5, 0),
		AnchorPoint = Vector2.new(0, 0.5),
		Size = UDim2.new(0, 26, 0, 26),
		BackgroundColor3 = Theme.PanelLight,
		ZIndex = 53,
		Parent = card,
	})
	corner(13, badge)
	new("TextLabel", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Font = FONT_BOLD,
		Text = style.glyph,
		TextColor3 = style.color,
		TextSize = 14,
		ZIndex = 54,
		Parent = badge,
	})

	local titleLbl = new("TextLabel", {
		Position = UDim2.new(0, 48, 0, 9),
		Size = UDim2.new(1, -76, 0, 16),
		BackgroundTransparency = 1,
		Font = FONT_BOLD,
		Text = title,
		TextColor3 = Theme.Text,
		TextTransparency = 1,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 53,
		Parent = card,
	})
	local bodyLbl = new("TextLabel", {
		Position = UDim2.new(0, 48, 0, 28),
		Size = UDim2.new(1, -76, 0, 16),
		BackgroundTransparency = 1,
		Font = FONT,
		Text = content,
		TextColor3 = Theme.SubText,
		TextTransparency = 1,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 53,
		Parent = card,
	})

	card.Size = UDim2.new(1, 0, 0, 0)
	tween(card, 0.3, { BackgroundTransparency = 0, Size = UDim2.new(1, 0, 0, 56) }, Enum.EasingStyle.Quint)
	tween(laser, 0.3, { Transparency = 0 })
	tween(titleLbl, 0.32, { TextTransparency = 0 })
	tween(bodyLbl, 0.32, { TextTransparency = 0 })

	local dismissing = false
	local function dismiss()
		if dismissing then return end
		dismissing = true
		if laserConn then laserConn:Disconnect() end
		tween(titleLbl, 0.14, { TextTransparency = 1 })
		tween(bodyLbl, 0.14, { TextTransparency = 1 })
		tween(laser, 0.2, { Transparency = 1 })
		tween(card, 0.32, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0) }, Enum.EasingStyle.Quint)
		task.delay(0.34, function() if card then card:Destroy() end end)
	end
	task.delay(duration, function() if card and card.Parent then dismiss() end end)
end

