function NexoUI:CreateWindow(opts)
	opts = opts or {}
	local sg = getScreenGui()
	self._sg = sg
	if opts.ConfigurationSaving and opts.ConfigurationSaving.Enabled then
		SaveManager.Enabled = true
		if opts.ConfigurationSaving.FolderName then SaveManager.Folder = opts.ConfigurationSaving.FolderName end
		if opts.ConfigurationSaving.FileName then SaveManager.FileName = opts.ConfigurationSaving.FileName end
	end

	-- notifications holder (top-right, like reference)
	self._notifyHolder = new("Frame", {
		Name = "Notifications", AnchorPoint = Vector2.new(1,0),
		Position = UDim2.new(1, -16, 0, 16), Size = UDim2.new(0, 280, 1, -32),
		BackgroundTransparency = 1, ZIndex = 50, Parent = sg,
	})
	vlist(self._notifyHolder, 10, Enum.HorizontalAlignment.Right)

	local main = new("Frame", {
		Name = "Main", AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(0.5,0,0.5,0),
		Size = UDim2.new(0, 860, 0, 540), BackgroundColor3 = Theme.Background,
		ClipsDescendants = true, Parent = sg,
	})
	corner(26, main)
	-- animated laser sweep border around the whole window
	local mainLaser = new("UIStroke", {
		Color = Color3.fromRGB(255, 255, 255),
		Thickness = 1.5,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		Parent = main,
	})
	local mainLaserGrad = new("UIGradient", {
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0,    Color3.fromRGB(60,  60,  80)),
			ColorSequenceKeypoint.new(0.42, Color3.fromRGB(150, 150, 180)),
			ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(255, 255, 255)),
			ColorSequenceKeypoint.new(0.58, Color3.fromRGB(150, 150, 180)),
			ColorSequenceKeypoint.new(1,    Color3.fromRGB(60,  60,  80)),
		}),
		Parent = mainLaser,
	})
	local mainSweep = 0
	local mainLaserConn
	mainLaserConn = RunService.RenderStepped:Connect(function(dt)
		if not main.Parent then mainLaserConn:Disconnect() return end
		mainSweep = (mainSweep + dt * 0.5) % 1
		mainLaserGrad.Offset = Vector2.new(mainSweep * 2 - 1, 0)
	end)
	-- OPTIONAL custom background image (set opts.Background or ASSETS.Background)
	local bgImage = opts.Background or ASSETS.Background
	if hasAsset(bgImage) then
		local bg = new("ImageLabel", { Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Image = bgImage,
			ScaleType = Enum.ScaleType.Crop, ImageTransparency = opts.BackgroundTransparency or 0.15, ZIndex = 0, Parent = main })
		corner(26, bg)
	end
	createStarfield(main, 110, 0, 26)

	-- RESPONSIVE SCALE: shrink the whole window on small screens so nothing
	-- ever clips off-screen (mobile / small viewports stay clean).
	local uiScale = new("UIScale", { Parent = main })
	local BASE_W, BASE_H = 860, 540
	local function fitScale()
		local cam = workspace.CurrentCamera
		if not cam then return end
		local vp = cam.ViewportSize
		if vp.X <= 0 or vp.Y <= 0 then return end
		-- cap a bit lower on desktop so the window stays compact on PC
		uiScale.Scale = math.clamp(math.min(vp.X / BASE_W, vp.Y / BASE_H) * 0.82, 0.5, 0.92)
	end
	fitScale()
	if workspace.CurrentCamera then
		workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(fitScale)
	end

	-- HEADER
	local header = new("Frame", { Size = UDim2.new(1,0,0,72), BackgroundTransparency = 1, ZIndex = 3, Parent = main })
	makeDraggable(main, header)
	-- thin divider under the header so the top bar reads cleanly
	local headerDivider = new("Frame", { Position = UDim2.new(0, 16, 0, 72), Size = UDim2.new(1, -32, 0, 1),
		BackgroundColor3 = Theme.Stroke, BorderSizePixel = 0, ZIndex = 3, Parent = main })
	-- TOP BAR: [logo]  NEXO UI  |  tagline ......  (minimize / close on the right)
	local headBar = new("Frame", { Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(1, -100, 1, 0),
		BackgroundTransparency = 1, ZIndex = 2, Parent = header })
	new("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, VerticalAlignment = Enum.VerticalAlignment.Center,
		HorizontalAlignment = Enum.HorizontalAlignment.Left, Padding = UDim.new(0, 12), SortOrder = Enum.SortOrder.LayoutOrder, Parent = headBar })
	if hasAsset(ASSETS.GalaxySpiral) then
		local logoImg = new("ImageLabel", { Size = UDim2.new(0, 60, 0, 60), BackgroundTransparency = 1, Image = ASSETS.GalaxySpiral,
			ScaleType = Enum.ScaleType.Crop, ClipsDescendants = true, LayoutOrder = 1, ZIndex = 2, Parent = headBar })
		corner(30, logoImg)
	end
	new("TextLabel", { AutomaticSize = Enum.AutomaticSize.X, Size = UDim2.new(0, 0, 0, 40), BackgroundTransparency = 1,
		Font = FONT_BOLD, Text = string.upper(opts.Title or "NEXO UI"), TextColor3 = Theme.Text, TextSize = 26,
		TextXAlignment = Enum.TextXAlignment.Left, LayoutOrder = 2, ZIndex = 2, Parent = headBar })
	if opts.Tagline then
		-- thin vertical line between the title and the tagline
		new("Frame", { Size = UDim2.new(0, 1, 0, 26), BackgroundColor3 = Theme.StrokeLight, BorderSizePixel = 0,
			LayoutOrder = 3, ZIndex = 2, Parent = headBar })
		new("TextLabel", { AutomaticSize = Enum.AutomaticSize.X, Size = UDim2.new(0, 0, 0, 36), BackgroundTransparency = 1,
			Font = FONT, Text = opts.Tagline, TextColor3 = Theme.SubText, TextSize = 12,
			TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Center, LayoutOrder = 4, ZIndex = 2, Parent = headBar })
	end

	-- window controls
	local controls = new("Frame", { AnchorPoint = Vector2.new(1,0), Position = UDim2.new(1,-16,0,18),
		Size = UDim2.new(0, 64, 0, 30), BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 0.5, ZIndex = 2, Parent = header })
	corner(14, controls) stroke(controls, Theme.Stroke, 1)
	new("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, HorizontalAlignment = Enum.HorizontalAlignment.Center,
		VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0,4), Parent = controls })
	local savedSize = main.Size
	local minimized = false
	local doMinimize
	local setMainOpen
	local function ctrl(glyph)
		local b = new("TextButton", { Size = UDim2.new(0,28,0,24), BackgroundTransparency = 1, Font = FONT,
			Text = glyph, TextColor3 = Theme.SubText, TextSize = 13, ZIndex = 2, Parent = controls })
		b.MouseEnter:Connect(function() tween(b, 0.1, { TextColor3 = Theme.Text }) end)
		b.MouseLeave:Connect(function() tween(b, 0.1, { TextColor3 = Theme.SubText }) end)
		return b
	end
	local minBtn, closeBtn = ctrl("\u{2014}"), ctrl("X")
	minBtn.MouseButton1Click:Connect(function()
		minimized = not minimized
		if doMinimize then doMinimize(minimized) end
	end)
	closeBtn.MouseButton1Click:Connect(function()
		if setMainOpen then setMainOpen(false) end
	end)

	-- CONTENT AREA (below the top tab strip)
	local content = new("Frame", { Position = UDim2.new(0, 16, 0, 128), Size = UDim2.new(1, -32, 1, -144),
		BackgroundTransparency = 1, ZIndex = 2, Parent = main })

	-- (profile card is rendered at the bottom of the left tab bar)

	-- TOP TAB BAR (horizontal navigation strip below the header)
	local tabBar = new("Frame", { AnchorPoint = Vector2.new(0,0), Position = UDim2.new(0, 16, 0, 80),
		Size = UDim2.new(1, -32, 0, 40), BackgroundTransparency = 1, ZIndex = 2, Parent = main })
	local tabHolder = new("ScrollingFrame", { Position = UDim2.new(0,0,0,0), Size = UDim2.new(1, -198, 1, 0), BackgroundTransparency = 1,
		ScrollBarThickness = 0, ScrollingDirection = Enum.ScrollingDirection.X,
		CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.X, ZIndex = 2, Parent = tabBar })
	new("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 8),
		VerticalAlignment = Enum.VerticalAlignment.Center, SortOrder = Enum.SortOrder.LayoutOrder, Parent = tabHolder }) pad(tabHolder, 0, 0, 2, 2)

	-- PROFILE CARD pinned to the right of the tab strip (circular avatar + name)
	local displayName = opts.DisplayName or LocalPlayer.DisplayName or "Player"
	local userName = opts.Username or LocalPlayer.Name or "player"
	local profile = new("Frame", { AnchorPoint = Vector2.new(1,0.5), Position = UDim2.new(1, 0, 0.5, 0),
		Size = UDim2.new(0, 188, 1, 0), BackgroundColor3 = Theme.Element, BackgroundTransparency = 0.5, ZIndex = 2, Parent = tabBar })
	corner(10, profile) stroke(profile, Theme.Stroke, 1)
	local avatar = new("ImageLabel", { AnchorPoint = Vector2.new(0,0.5), Position = UDim2.new(0,8,0.5,0),
		Size = UDim2.new(0,34,0,34), BackgroundColor3 = Theme.PanelLight, BackgroundTransparency = 1,
		ClipsDescendants = true, ImageTransparency = 0, ScaleType = Enum.ScaleType.Crop, ZIndex = 2, Parent = profile, Name = "Avatar" })
	corner(17, avatar) stroke(avatar, Theme.StrokeLight, 1)
	if hasAsset(opts.Avatar) then
		avatar.Image = opts.Avatar
	else
		avatar.Image = "rbxthumb://type=AvatarHeadShot&id=" .. LocalPlayer.UserId .. "&w=150&h=150"
	end
	new("TextLabel", { Position = UDim2.new(0,50,0,8), Size = UDim2.new(1,-58,0,16), BackgroundTransparency = 1,
		Font = FONT_BOLD, Text = displayName .. "  \u{2713}", TextColor3 = Theme.Text, TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 2, Parent = profile })
	new("TextLabel", { Position = UDim2.new(0,50,0,26), Size = UDim2.new(1,-58,0,14), BackgroundTransparency = 1,
		Font = FONT, Text = "@" .. userName, TextColor3 = Theme.SubText, TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 2, Parent = profile })

	function doMinimize(state)
		content.Visible = not state
		tabBar.Visible = not state
		headerDivider.Visible = not state
		tween(main, 0.25, { Size = state and UDim2.new(0, savedSize.X.Offset, 0, 64) or savedSize })
	end

	--========================================================
	-- MINI LAUNCHER (floating draggable icon: open/close the UI)
	--========================================================
	local miniIcon = opts.MiniIcon or ASSETS.MiniIcon
	local mini = new("ImageButton", {
		Name = "MiniLauncher", AnchorPoint = Vector2.new(0.5, 0.5), ClipsDescendants = true,
		Position = UDim2.new(0, 64, 0.5, 0), Size = UDim2.new(0, 48, 0, 48),
		BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 0.15,
		Image = hasAsset(miniIcon) and miniIcon or "rbxthumb://type=AvatarHeadShot&id=" .. LocalPlayer.UserId .. "&w=48&h=48",
		ImageTransparency = 0, ScaleType = Enum.ScaleType.Crop,
		AutoButtonColor = false, ZIndex = 60, Parent = sg,
	})
	corner(24, mini)
	local mLaser = new("UIStroke", { Color = Color3.fromRGB(255,255,255), Thickness = 1.6,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Parent = mini })
	local mLaserGrad = new("UIGradient", { Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(40,40,55)),
		ColorSequenceKeypoint.new(0.45, Color3.fromRGB(150,150,180)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,255,255)),
		ColorSequenceKeypoint.new(0.55, Color3.fromRGB(150,150,180)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(40,40,55)),
	}), Parent = mLaser })
	local mSweep = 0
	local mLaserConn = RunService.RenderStepped:Connect(function(dt)
		if not mini.Parent then mLaserConn:Disconnect() return end
		mSweep = (mSweep + dt * 0.8) % 1
		mLaserGrad.Offset = Vector2.new(mSweep * 2 - 1, 0)
	end)
	local windowOpen = true
	function setMainOpen(open)
		if open == windowOpen then return end
		windowOpen = open
		if open then
			-- always reopen as a FULL, un-minimized window (fixes empty window after close)
			minimized = false
			content.Visible = true
			tabBar.Visible = true
			headerDivider.Visible = true
			main.Visible = true
			main.Position = UDim2.new(0.5, 0, 0.5, 0) -- always reopen centered in the middle
			main.Size = UDim2.new(0, 0, 0, 0)
			tween(main, 0.32, { Size = savedSize }, Enum.EasingStyle.Back)
		else
			tween(main, 0.26, { Size = UDim2.new(0, 0, 0, 0) }, Enum.EasingStyle.Quart).Completed:Connect(function()
				if not windowOpen then main.Visible = false end
			end)
		end
	end
	-- KEYBIND: press K to toggle (open / close) the whole UI
	UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if GateState.locked then return end
		if input.KeyCode == Enum.KeyCode.K then
			setMainOpen(not windowOpen)
		end
	end)

	local mDragging, mStart, mStartPos, mMoved
	mini.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			mDragging = true mMoved = false mStart = input.Position mStartPos = mini.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then mDragging = false end
			end)
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if mDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - mStart
			if delta.Magnitude > 4 then mMoved = true end
			mini.Position = UDim2.new(mStartPos.X.Scale, mStartPos.X.Offset + delta.X, mStartPos.Y.Scale, mStartPos.Y.Offset + delta.Y)
		end
	end)
	mini.Activated:Connect(function()
		if mMoved then return end
		setMainOpen(not windowOpen)
		tween(mini, 0.12, { Size = UDim2.new(0, 42, 0, 42) }).Completed:Connect(function()
			tween(mini, 0.12, { Size = UDim2.new(0, 48, 0, 48) })
		end)
	end)

	local Window = setmetatable({}, { __index = self })
	Window._tabs = {}
	-- animate the selected tab's laser-sweep border
	local tabSweep = 0
	RunService.RenderStepped:Connect(function(dt)
		if not main.Parent then return end
		if Window._activeGrad then
			tabSweep = (tabSweep + dt * 0.7) % 1
			Window._activeGrad.Offset = Vector2.new(tabSweep * 2 - 1, 0)
		end
	end)

	function Window:CreateTab(name, icon)
		-- top-strip tab styled as an auto-width pill BUTTON (icon + label)
		local btn = new("TextButton", { Size = UDim2.new(0, 0, 0, 30), AutomaticSize = Enum.AutomaticSize.X,
			BackgroundColor3 = Color3.fromRGB(0, 0, 0), AutoButtonColor = false, Text = "", ZIndex = 2, Parent = tabHolder })
		corner(10, btn)
		local tabStroke = stroke(btn, Theme.Stroke, 1.5)
		local tabGrad = new("UIGradient", {
			Enabled = false,
			Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.fromRGB(60, 60, 80)),
				ColorSequenceKeypoint.new(0.42, Color3.fromRGB(150, 150, 180)),
				ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
				ColorSequenceKeypoint.new(0.58, Color3.fromRGB(150, 150, 180)),
				ColorSequenceKeypoint.new(1, Color3.fromRGB(60, 60, 80)),
			}),
			Parent = tabStroke,
		})
		new("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 8),
			VerticalAlignment = Enum.VerticalAlignment.Center, HorizontalAlignment = Enum.HorizontalAlignment.Center, SortOrder = Enum.SortOrder.LayoutOrder, Parent = btn })
		new("UIPadding", { PaddingLeft = UDim.new(0,14), PaddingRight = UDim.new(0,14), Parent = btn })
		if hasAsset(icon) then
			new("ImageLabel", { Size = UDim2.new(0,16,0,16), BackgroundTransparency = 1, Image = icon,
				ImageColor3 = Theme.SubText, LayoutOrder = 1, ZIndex = 2, Parent = btn, Name = "Ico" })
		end
		local lbl = new("TextLabel", { AutomaticSize = Enum.AutomaticSize.X, Size = UDim2.new(0, 0, 1, 0),
			BackgroundTransparency = 1, Font = FONT_MED, Text = name, TextColor3 = Theme.SubText, TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Center, LayoutOrder = 2, ZIndex = 2, Parent = btn })

		local page = new("ScrollingFrame", { Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1,
			ScrollBarThickness = 3, ScrollBarImageColor3 = Theme.StrokeLight, ScrollBarImageTransparency = 1,
			CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y, Visible = false, ZIndex = 2, Parent = content })
		vlist(page, 12) pad(page, 4, 16, 2, 12)

		local function paint(b, l, active)
			tween(b, 0.12, { BackgroundColor3 = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(0, 0, 0), BackgroundTransparency = active and 0 or 0.45 })
			tween(l, 0.12, { TextColor3 = active and Color3.fromRGB(12, 12, 15) or Theme.SubText })
			local i = b:FindFirstChild("Ico")
			if i then tween(i, 0.12, { ImageColor3 = active and Color3.fromRGB(12, 12, 15) or Theme.SubText }) end
		end
		local function activate()
			for _, t in ipairs(Window._tabs) do
				t.page.Visible = false
				paint(t.btn, t.lbl, false)
				if t.grad then t.grad.Enabled = false end
				if t.stroke then t.stroke.Color = Theme.Stroke end
			end
			page.Visible = true
			paint(btn, lbl, true)
			tabStroke.Color = Color3.fromRGB(255, 255, 255)
			tabGrad.Enabled = true
			Window._activeGrad = tabGrad
		end
		btn.MouseButton1Click:Connect(activate)
		table.insert(Window._tabs, { btn = btn, lbl = lbl, page = page, stroke = tabStroke, grad = tabGrad })
		if #Window._tabs == 1 then activate() end

		-- Tab gets element factories directly, plus CreateGroup for cards
		local Tab = buildElements(page, self)
		function Tab:CreateGroup(gopts)
			gopts = gopts or {}
			local height = gopts.Height or 240
			local card = new("Frame", { Size = UDim2.new(1,0,0,height),
				BackgroundColor3 = Theme.Panel, BackgroundTransparency = 0.5, ClipsDescendants = true, ZIndex = 2, Parent = page })
			corner(12, card) stroke(card, Theme.Stroke, 1)
			local inner = new("Frame", { Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Parent = card })
			pad(inner, 14, 14, 14, 14)
			local top = 0
			if gopts.Title then
				new("TextLabel", { Size = UDim2.new(1,0,0,16), BackgroundTransparency = 1, Font = FONT_BOLD,
					Text = string.upper(gopts.Title), TextColor3 = Theme.SubText, TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left, Parent = inner })
				top = 24
			end
			-- each group scrolls on its own
			local scroll = new("ScrollingFrame", { Position = UDim2.new(0,0,0,top), Size = UDim2.new(1,0,1,-top),
				BackgroundTransparency = 1, ScrollBarThickness = 3, ScrollBarImageColor3 = Theme.StrokeLight, ScrollBarImageTransparency = 1,
				CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y,
				ScrollingDirection = Enum.ScrollingDirection.Y, ZIndex = 2, Parent = inner })
			vlist(scroll, 10) pad(scroll, 4, 4, 4, 8)
			return buildElements(scroll, self)
		end

		-- COLUMNS: lay sections side-by-side in a responsive grid.
		-- local cols = Tab:CreateColumns(3); cols[1]:CreateGroup({ Title = "..." })
		function Tab:CreateColumns(count)
			count = math.max(1, math.floor(count or 2))
			local rowFrame = new("Frame", { Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
				BackgroundTransparency = 1, ZIndex = 2, Parent = page })
			new("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 12),
				HorizontalAlignment = Enum.HorizontalAlignment.Left, VerticalAlignment = Enum.VerticalAlignment.Top,
				SortOrder = Enum.SortOrder.LayoutOrder, Parent = rowFrame })
			local cols = {}
			for i = 1, count do
				local col = new("Frame", { Size = UDim2.new(1 / count, -12 * (count - 1) / count, 0, 0),
					AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1, LayoutOrder = i, ZIndex = 2, Parent = rowFrame })
				vlist(col, 12)
				local colApi = buildElements(col, self)
				function colApi:CreateGroup(gopts)
					gopts = gopts or {}
					local height = gopts.Height or 240
					local card = new("Frame", { Size = UDim2.new(1, 0, 0, height),
						BackgroundColor3 = Theme.Panel, BackgroundTransparency = 0.5, ClipsDescendants = true, ZIndex = 2, Parent = col })
					corner(12, card) stroke(card, Theme.Stroke, 1)
					local inner = new("Frame", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Parent = card })
					pad(inner, 14, 14, 14, 14)
					local top = 0
					if gopts.Title then
						new("TextLabel", { Size = UDim2.new(1, 0, 0, 16), BackgroundTransparency = 1, Font = FONT_BOLD,
							Text = string.upper(gopts.Title), TextColor3 = Theme.SubText, TextSize = 12,
							TextXAlignment = Enum.TextXAlignment.Left, Parent = inner })
						top = 24
					end
					-- each group scrolls on its own
					local scroll = new("ScrollingFrame", { Position = UDim2.new(0, 0, 0, top), Size = UDim2.new(1, 0, 1, -top),
						BackgroundTransparency = 1, ScrollBarThickness = 3, ScrollBarImageColor3 = Theme.StrokeLight, ScrollBarImageTransparency = 1,
						CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y,
						ScrollingDirection = Enum.ScrollingDirection.Y, ZIndex = 2, Parent = inner })
					vlist(scroll, 10) pad(scroll, 4, 4, 4, 8)
					return buildElements(scroll, self)
				end
				cols[i] = colApi
			end
			return cols
		end

		return Tab
	end

	-- BUILT-IN KEY SYSTEM: pass KeySystem = { Key = "x_375" } to CreateWindow and the
	-- whole UI (window + mini launcher + keybinds) stays hidden/disabled until the
	-- correct key is entered. No need to wrap your code in a buildUI function.
	if opts.KeySystem then
		local ks = opts.KeySystem
		GateState.locked = true
		main.Visible = false
		mini.Visible = false
		self:CreateKeySystem({
			Title = ks.Title or opts.Title or "NEXO UI",
			Subtitle = ks.Subtitle or "KEY SYSTEM",
			Note = ks.Note or "Enter your key to continue.",
			Key = ks.Key or ks.Keys,
			Link = ks.Link,
			OnSuccess = function()
				GateState.locked = false
				main.Visible = true
				mini.Visible = true
				if ks.OnSuccess then task.spawn(ks.OnSuccess) end
			end,
			OnClose = ks.OnClose,
		})
	end

	function Window:SetVisibility(state) setMainOpen(state and true or false) end
	function Window:IsVisible() return windowOpen end
	function Window:SaveConfiguration() SaveManager:Save() end
	function Window:LoadConfiguration() SaveManager:Load() end
	function Window:Destroy()
		pcall(function()
			if NexoUI._activeGui then NexoUI._activeGui:Destroy() NexoUI._activeGui = nil end
		end)
	end
	if SaveManager.Enabled then task.defer(function() SaveManager:Load() end) end

	return Window
end

function NexoUI:Destroy()
	pcall(function()
		if NexoUI._activeGui then NexoUI._activeGui:Destroy() NexoUI._activeGui = nil end
	end)
end

return setmetatable({}, NexoUI)
