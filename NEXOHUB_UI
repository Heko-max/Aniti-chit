	-- Color picker (HSV square + hue slider + hex), NEXO black/white style
	function E:CreateColorPicker(opts)
		opts = opts or {}
		local color = opts.Default or opts.Color or Color3.fromRGB(255, 255, 255)
		local h, s, v = color:ToHSV()
		local open = false
		local row = baseRow(38)
		row.ClipsDescendants = true
		new("TextLabel", {
			Size = UDim2.new(1, -52, 0, 38), BackgroundTransparency = 1,
			Font = FONT, Text = opts.Title or "Color Picker", TextColor3 = Theme.Text, TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left, Parent = row,
		})
		local swatch = new("TextButton", {
			AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, 0, 0, 8),
			Size = UDim2.new(0, 40, 0, 22), BackgroundColor3 = color, AutoButtonColor = false, Text = "", Parent = row,
		})
		corner(6, swatch)
		stroke(swatch, Theme.StrokeLight, 1)
		local canvas = new("Frame", {
			Position = UDim2.new(0, 0, 0, 46), Size = UDim2.new(1, 0, 0, 90),
			BackgroundColor3 = Color3.fromHSV(h, 1, 1), BorderSizePixel = 0, Parent = row,
		})
		corner(8, canvas)
		canvas.ClipsDescendants = true
		local whiteOv = new("Frame", { Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0, Parent = canvas })
		corner(8, whiteOv)
		new("UIGradient", {
			Color = ColorSequence.new(Color3.fromRGB(255,255,255)),
			Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1) }),
			Parent = whiteOv,
		})
		local blackOv = new("Frame", { Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(0,0,0), BorderSizePixel = 0, Parent = canvas })
		corner(8, blackOv)
		new("UIGradient", {
			Rotation = 90,
			Color = ColorSequence.new(Color3.fromRGB(0,0,0)),
			Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0) }),
			Parent = blackOv,
		})
		local svPoint = new("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5), Size = UDim2.new(0, 10, 0, 10),
			BackgroundColor3 = Color3.fromRGB(255,255,255), Parent = canvas,
		})
		corner(5, svPoint)
		stroke(svPoint, Color3.fromRGB(0,0,0), 1)
		local hue = new("Frame", {
			Position = UDim2.new(0, 0, 0, 142), Size = UDim2.new(1, 0, 0, 12),
			BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0, Parent = row,
		})
		corner(6, hue)
		new("UIGradient", {
			Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
				ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
				ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
				ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0, 255, 255)),
				ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
				ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
				ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
			}),
			Parent = hue,
		})
		local huePoint = new("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(h, 0, 0.5, 0),
			Size = UDim2.new(0, 6, 0, 16), BackgroundColor3 = Color3.fromRGB(255,255,255), Parent = hue,
		})
		corner(3, huePoint)
		stroke(huePoint, Color3.fromRGB(0,0,0), 1)
		local hexRow = new("Frame", {
			Position = UDim2.new(0, 0, 0, 162), Size = UDim2.new(1, 0, 0, 28),
			BackgroundColor3 = Theme.PanelLight, Parent = row,
		})
		corner(6, hexRow)
		stroke(hexRow, Theme.Stroke, 1)
		pad(hexRow, 0, 0, 10, 10)
		local hexBox = new("TextBox", {
			Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Font = FONT,
			Text = "", PlaceholderText = "#FFFFFF", PlaceholderColor3 = Theme.SubText, TextColor3 = Theme.Text,
			TextSize = 12, ClearTextOnFocus = false, TextXAlignment = Enum.TextXAlignment.Left, Parent = hexRow,
		})
		local function currentColor() return Color3.fromHSV(h, s, v) end
		local function refresh(fireCb)
			local c = currentColor()
			swatch.BackgroundColor3 = c
			canvas.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
			svPoint.Position = UDim2.new(s, 0, 1 - v, 0)
			svPoint.BackgroundColor3 = c
			huePoint.Position = UDim2.new(h, 0, 0.5, 0)
			hexBox.Text = string.format("#%02X%02X%02X", math.floor(c.R*255+0.5), math.floor(c.G*255+0.5), math.floor(c.B*255+0.5))
			if fireCb and opts.Callback then opts.Callback(c) end
			if fireCb and opts.Flag then SaveManager:Mark(opts.Flag) end
		end
		refresh(false)
		swatch.MouseButton1Click:Connect(function()
			open = not open
			tween(row, 0.18, { Size = UDim2.new(1, 0, 0, open and 200 or 38) })
		end)
		local svDrag, hueDrag = false, false
		local function updateSV(px, py)
			local rx = math.clamp((px - canvas.AbsolutePosition.X) / math.max(canvas.AbsoluteSize.X, 1), 0, 1)
			local ry = math.clamp((py - canvas.AbsolutePosition.Y) / math.max(canvas.AbsoluteSize.Y, 1), 0, 1)
			s = rx
			v = 1 - ry
			refresh(true)
		end
		local function updateHue(px)
			h = math.clamp((px - hue.AbsolutePosition.X) / math.max(hue.AbsoluteSize.X, 1), 0, 1)
			refresh(true)
		end
		canvas.InputBegan:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
				svDrag = true updateSV(i.Position.X, i.Position.Y)
			end
		end)
		hue.InputBegan:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
				hueDrag = true updateHue(i.Position.X)
			end
		end)
		UserInputService.InputChanged:Connect(function(i)
			if not row.Parent then return end
			if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
				if svDrag then updateSV(i.Position.X, i.Position.Y) elseif hueDrag then updateHue(i.Position.X) end
			end
		end)
		UserInputService.InputEnded:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
				svDrag = false hueDrag = false
			end
		end)
		hexBox.FocusLost:Connect(function()
			local t = string.gsub(hexBox.Text, "#", "")
			if #t >= 6 then
				local r = tonumber(string.sub(t,1,2), 16)
				local g = tonumber(string.sub(t,3,4), 16)
				local b = tonumber(string.sub(t,5,6), 16)
				if r and g and b then
					h, s, v = Color3.fromRGB(r, g, b):ToHSV()
					refresh(true)
				else refresh(false) end
			else refresh(false) end
		end)
		local handle = {
			Get = function() return currentColor() end,
			Set = function(c)
				if typeof(c) == "Color3" then h, s, v = c:ToHSV() refresh(true) end
			end,
		}
		if opts.Flag then SaveManager:Bind(opts.Flag, handle, "color") end
		return handle
	end

	return E
end

