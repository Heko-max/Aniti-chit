	function E:CreateKeybind(opts)
		opts = opts or {}
		local key = opts.Default or Enum.KeyCode.E
		local binding = false
		local isToggle = opts.Toggle or false
		local toggleState = false
		local row = baseRow()
		local keyBox = new("TextLabel", {
			Position = UDim2.new(0,0,0.5,0), AnchorPoint = Vector2.new(0,0.5),
			Size = UDim2.new(0,30,0,24), BackgroundColor3 = Theme.PanelLight,
			Font = FONT_BOLD, Text = key.Name, TextColor3 = Theme.Text, TextSize = 12, Parent = row })
		corner(5, keyBox) stroke(keyBox, Theme.Stroke, 1)
		new("TextLabel", { Position = UDim2.new(0,42,0,0), Size = UDim2.new(1,-86,1,0), BackgroundTransparency = 1,
			Font = FONT, Text = opts.Title or "Keybind", TextColor3 = Theme.SubText, TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left, Parent = row })
		-- ON/OFF badge (only when Toggle = true)
		local stateLbl
		if isToggle then
			stateLbl = new("TextLabel", {
				AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, 0, 0.5, 0),
				Size = UDim2.new(0, 36, 0, 20), BackgroundColor3 = Theme.ToggleOff,
				Font = FONT_BOLD, Text = "OFF", TextColor3 = Theme.SubText, TextSize = 11, Parent = row })
			corner(5, stateLbl)
		end
		local hit = new("TextButton", { Size = UDim2.new(0,30,0,24), Position = UDim2.new(0,0,0.5,0), AnchorPoint = Vector2.new(0,0.5),
			BackgroundTransparency = 1, Text = "", Parent = row })
		hit.MouseButton1Click:Connect(function() binding = true keyBox.Text = "..." end)
		UserInputService.InputBegan:Connect(function(input, gpe)
			if binding and input.UserInputType == Enum.UserInputType.Keyboard then
				key = input.KeyCode keyBox.Text = key.Name binding = false
			elseif not gpe and input.KeyCode == key then
				if GateState.locked then return end
				if isToggle then
					toggleState = not toggleState
					if stateLbl then
						stateLbl.Text = toggleState and "ON" or "OFF"
						tween(stateLbl, 0.12, {
							BackgroundColor3 = toggleState and Theme.Success or Theme.ToggleOff,
							TextColor3 = toggleState and Color3.fromRGB(10,10,12) or Theme.SubText,
						})
					end
					if opts.Callback then opts.Callback(toggleState) end
				else
					if opts.Callback then opts.Callback() end
				end
			end
		end)
		return {
			Get = function() return key end,
			GetState = function() return toggleState end,
			SetState = function(v)
				toggleState = v
				if stateLbl then
					stateLbl.Text = toggleState and "ON" or "OFF"
					tween(stateLbl, 0.12, {
						BackgroundColor3 = toggleState and Theme.Success or Theme.ToggleOff,
						TextColor3 = toggleState and Color3.fromRGB(10,10,12) or Theme.SubText,
					})
				end
			end,
		}
	end

