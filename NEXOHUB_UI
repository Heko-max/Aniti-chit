	getBtn.MouseLeave:Connect(function() tween(getBtn, 0.12, { TextColor3 = Theme.SubText }) end)

	local closed = false
	local function destroyAll()
		if closed then return end
		closed = true
		if laserConn then laserConn:Disconnect() end
		tween(backdrop, 0.25, { BackgroundTransparency = 1 })
		tween(card, 0.25, { BackgroundTransparency = 1, Size = UDim2.new(0, 380, 0, 0) }, Enum.EasingStyle.Quint)
		task.delay(0.28, function()
			if card then card:Destroy() end
			if backdrop then backdrop:Destroy() end
		end)
	end

	local function shake()
		for _, dx in ipairs({ -10, 10, -7, 7, -3, 3, 0 }) do
			card.Position = UDim2.new(0.5, dx, 0.5, 0)
			task.wait(0.03)
		end
	end

	local function validate()
		local entered = box.Text
		local ok = false
		for _, k in ipairs(keys) do
			if entered == k then ok = true break end
		end
		if ok then
			statusLbl.Text = "Key accepted."
			statusLbl.TextColor3 = Theme.Success
			task.wait(0.15)
			destroyAll()
			if opts.OnSuccess then task.spawn(opts.OnSuccess) end
		else
			statusLbl.Text = "Invalid key. Try again."
			statusLbl.TextColor3 = Theme.Error
			box.Text = ""
			task.spawn(shake)
		end
	end

	checkBtn.MouseButton1Click:Connect(validate)
	box.FocusLost:Connect(function(enter) if enter then validate() end end)

	getBtn.MouseButton1Click:Connect(function()
		if link then
			if setclipboard then setclipboard(link) end
			statusLbl.Text = "Key link copied to clipboard."
			statusLbl.TextColor3 = Theme.Info
		else
			destroyAll()
			if opts.OnClose then task.spawn(opts.OnClose) end
		end
	end)

	-- entrance grow
	card.Size = UDim2.new(0, 380, 0, 0)
	tween(card, 0.3, { Size = UDim2.new(0, 380, 0, 300) }, Enum.EasingStyle.Quint)

	return { Destroy = destroyAll }
end

--========================================================
-- ELEMENT FACTORIES (shared by Tab and Group)
--========================================================
local function buildElements(container, lib)
	local E = {}

	local function baseRow(height)
		local row = new("Frame", {
			Size = UDim2.new(1, 0, 0, height or 38), BackgroundTransparency = 0.5,
			BackgroundColor3 = Theme.Element,
			Parent = container,
		})
		corner(8, row)
		stroke(row, Theme.Stroke, 1)
		pad(row, 0, 0, 12, 12)
		return row
	end

	function E:CreateLabel(text)
		return new("TextLabel", {
			Size = UDim2.new(1, 0, 0, 18),
			BackgroundTransparency = 1,
			Font = FONT,
			Text = text or "",
			TextColor3 = Theme.SubText,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = container,
		})
	end

	function E:CreateButton(opts)
		opts = opts or {}
		local variant = opts.Variant or "Secondary"
		local btn = new("TextButton", {
			Size = UDim2.new(1, 0, 0, 36),
			Font = FONT_MED,
			Text = opts.Title or "Button",
			TextSize = 13,
			AutoButtonColor = false,
			Parent = container,
		})
		corner(8, btn)

		if variant == "Primary" then
			btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			btn.TextColor3 = Theme.Text
			new("UIGradient", {
				Color = ColorSequence.new(Color3.fromRGB(0,0,0), Color3.fromRGB(0,0,0)),
				Rotation = 90,
				Parent = btn,
			})
		elseif variant == "Outline" then
			btn.BackgroundTransparency = 1
			btn.TextColor3 = Theme.Text
			stroke(btn, Theme.StrokeLight, 1)
		elseif variant == "Ghost" then
			btn.BackgroundTransparency = 1
			btn.TextColor3 = Theme.SubText
		elseif variant == "Icon" then
			btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0) btn.BackgroundTransparency = 0.5
			btn.TextColor3 = Theme.Text
			btn.Text = (opts.Glyph or "\u{2605}") .. "   " .. (opts.Title or "")
			stroke(btn, Theme.Stroke, 1)
		else -- Secondary
			btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0) btn.BackgroundTransparency = 0.5
			btn.TextColor3 = Theme.Text
			stroke(btn, Theme.Stroke, 1)
		end

		btn.MouseEnter:Connect(function()
			if variant == "Primary" then return end
			tween(btn, 0.12, { BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = (variant=="Outline" or variant=="Ghost") and 0.9 or 0.3 })
		end)
		btn.MouseLeave:Connect(function()
			if variant == "Primary" then return end
			tween(btn, 0.12, { BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = (variant=="Outline" or variant=="Ghost") and 1 or 0.5 })
		end)
		btn.MouseButton1Click:Connect(function() if opts.Callback then opts.Callback() end end)
		return btn
	end

	function E:CreateInput(opts)
		opts = opts or {}
		local multiline = opts.Multiline
		local row = new("Frame", {
			Size = UDim2.new(1, 0, 0, multiline and 64 or 36), BackgroundTransparency = 0.5, ClipsDescendants = true,
			BackgroundColor3 = Theme.Element,
			Parent = container,
		})
		corner(8, row)
		stroke(row, Theme.Stroke, 1)
		pad(row, 0, 0, 12, 10)

		if opts.Glyph then
			new("TextLabel", {
				Position = UDim2.new(0, 0, 0, 0),
				Size = UDim2.new(0, 18, 1, 0),
				BackgroundTransparency = 1,
				Font = FONT, Text = opts.Glyph, TextColor3 = Theme.SubText, TextSize = 13,
				Parent = row,
			})
		end
		local box = new("TextBox", {
			Position = UDim2.new(0, opts.Glyph and 24 or 0, 0, 0),
			Size = UDim2.new(1, opts.Glyph and -52 or (opts.Password and -28 or 0), 1, 0),
			BackgroundTransparency = 1,
			Font = FONT,
			Text = "",
			PlaceholderText = opts.Placeholder or "...",
			PlaceholderColor3 = Theme.SubText,
			TextColor3 = Theme.Text,
			TextSize = 13,
			ClearTextOnFocus = false,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = multiline and Enum.TextYAlignment.Top or Enum.TextYAlignment.Center,
			MultiLine = multiline or false,
			TextWrapped = multiline or false,
			Parent = row,
		})
		if opts.Password then
			local hidden = true
			box.Text = ""
			local real = ""
			local eye = new("TextButton", {
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, 0, 0.5, 0),
				Size = UDim2.new(0, 20, 0, 20),
				BackgroundTransparency = 1,
				Font = FONT, Text = "\u{1F441}", TextColor3 = Theme.SubText, TextSize = 13,
				Parent = row,
			})
			box:GetPropertyChangedSignal("Text"):Connect(function()
				if hidden then
					if #box.Text >= #real then real = real .. box.Text:sub(#real + 1) else real = real:sub(1, #box.Text) end
					local masked = string.rep("*", #real)
					if box.Text ~= masked then box.Text = masked end
				else
					real = box.Text
				end
			end)
			eye.MouseButton1Click:Connect(function()
				hidden = not hidden
				eye.TextColor3 = hidden and Theme.SubText or Theme.Accent
				box.Text = hidden and string.rep("*", #real) or real
			end)
			box.FocusLost:Connect(function(enter) if opts.Callback then opts.Callback(real, enter) end end)
		else
			box.FocusLost:Connect(function(enter) if opts.Callback then opts.Callback(box.Text, enter) end if opts.Flag then SaveManager:Mark(opts.Flag) end end)
		end
		if opts.Flag then
			SaveManager:Bind(opts.Flag, { Get = function() return box.Text end, Set = function(v) box.Text = tostring(v or "") if opts.Callback then opts.Callback(box.Text, false) end end }, "value")
		end
		return box
	end

	function E:CreateToggle(opts)
		opts = opts or {}
		local state = opts.Default or false
		local disabled = opts.Disabled or false
		local row = baseRow()
		new("TextLabel", {
			Size = UDim2.new(1, -54, 1, 0),
			BackgroundTransparency = 1,
			Font = FONT, Text = opts.Title or "Toggle",
			TextColor3 = disabled and Theme.SubText or Theme.Text,
			TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left,
			Parent = row,
		})
		local pill = new("TextButton", {
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, 0, 0.5, 0),
			Size = UDim2.new(0, 42, 0, 22),
			BackgroundColor3 = state and Theme.Accent or Theme.ToggleOff,
			BackgroundTransparency = disabled and 0.5 or 0,
			Text = "", AutoButtonColor = false,
			Parent = row,
		})
		corner(11, pill)
		local knob = new("Frame", {
			AnchorPoint = Vector2.new(0, 0.5),
			Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
			Size = UDim2.new(0, 18, 0, 18),
			BackgroundColor3 = state and Color3.fromRGB(10,10,12) or Color3.fromRGB(200,200,210),
			Parent = pill,
		})
		corner(9, knob)
		local function set(v)
			if disabled then return end
			state = v
			tween(pill, 0.15, { BackgroundColor3 = state and Theme.Accent or Theme.ToggleOff })
			tween(knob, 0.15, {
				Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
				BackgroundColor3 = state and Color3.fromRGB(10,10,12) or Color3.fromRGB(200,200,210),
			})
			if opts.Callback then opts.Callback(state) end
			if opts.Flag then SaveManager:Mark(opts.Flag) end
		end
		pill.MouseButton1Click:Connect(function() set(not state) end)
		local _h = { Set = set, Get = function() return state end }
		if opts.Flag then SaveManager:Bind(opts.Flag, _h, "value") end
		return _h
	end

	function E:CreateSlider(opts)
		opts = opts or {}
		local min, max = opts.Min or 0, opts.Max or 100
		local value = opts.Default or min
		local suffix = opts.Suffix or "%"
		local row = baseRow(66)
		
		pad(row, 8, 8, 12, 12)
		local header = new("Frame", { Size = UDim2.new(1, 0, 0, 14), Position = UDim2.new(0, 0, 0, 18), BackgroundTransparency = 1, Parent = row })
		new("TextLabel", {
			Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
			Font = FONT, Text = opts.Title or "Slider", TextColor3 = Theme.Text, TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left, Parent = header,
		})
		local valLbl = new("TextLabel", {
			AnchorPoint = Vector2.new(1,0), Position = UDim2.new(1,0,0,0),
			Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
			Font = FONT_MED, Text = value .. suffix, TextColor3 = Theme.Accent, TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Right, Parent = header,
		})
		local track = new("Frame", { AnchorPoint = Vector2.new(0, 0), Position = UDim2.new(0, 0, 0, 38), Size = UDim2.new(1, 0, 0, 5), BackgroundColor3 = Theme.ToggleOff, Parent = row })
		corner(3, track)
		local fill = new("Frame", { Size = UDim2.new((value-min)/(max-min), 0, 1, 0), BackgroundColor3 = Theme.Accent, Parent = track })
		corner(3, fill)
		local knob = new("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new((value-min)/(max-min), 0, 0.5, 0),
			Size = UDim2.new(0, 12, 0, 12), BackgroundColor3 = Theme.Accent, Parent = track,
		})
		corner(6, knob)
		local dragging = false
		local function update(px)
			local rel = math.clamp((px - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
			value = math.floor((min + (max-min)*rel) + 0.5)
			fill.Size = UDim2.new(rel, 0, 1, 0)
			knob.Position = UDim2.new(rel, 0, 0.5, 0)
			valLbl.Text = value .. suffix
			if opts.Callback then opts.Callback(value) end
			if opts.Flag then SaveManager:Mark(opts.Flag) end
		end
		track.InputBegan:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
				dragging = true update(i.Position.X)
			end
		end)
		UserInputService.InputChanged:Connect(function(i)
			if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i.Position.X) end
		end)
		UserInputService.InputEnded:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
		end)
		local function setValue(nv)
			nv = math.clamp(math.floor((tonumber(nv) or value) + 0.5), min, max)
			local rel = (nv - min) / (max - min)
			value = nv
			fill.Size = UDim2.new(rel, 0, 1, 0)
			knob.Position = UDim2.new(rel, 0, 0.5, 0)
			valLbl.Text = value .. suffix
			if opts.Callback then opts.Callback(value) end
			if opts.Flag then SaveManager:Mark(opts.Flag) end
		end
		local _h = { Get = function() return value end, Set = setValue }
		if opts.Flag then SaveManager:Bind(opts.Flag, _h, "value") end
		return _h
	end

	function E:CreateRangeSlider(opts)
		opts = opts or {}
		local min, max = opts.Min or 0, opts.Max or 100
		local lo = opts.DefaultMin or min
		local hi = opts.DefaultMax or max
		local suffix = opts.Suffix or "%"
		local row = baseRow(66)
		
		pad(row, 8, 8, 12, 12)
		local header = new("Frame", { Size = UDim2.new(1, 0, 0, 14), Position = UDim2.new(0, 0, 0, 18), BackgroundTransparency = 1, Parent = row })
		new("TextLabel", { Size = UDim2.new(0.6,0,1,0), BackgroundTransparency = 1, Font = FONT,
			Text = opts.Title or "Range", TextColor3 = Theme.Text, TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left, Parent = header })
		local valLbl = new("TextLabel", { AnchorPoint = Vector2.new(1,0), Position = UDim2.new(1,0,0,0),
			Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Font = FONT_MED,
			Text = lo..suffix.." - "..hi..suffix, TextColor3 = Theme.Accent, TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Right, Parent = header })
		local track = new("Frame", { AnchorPoint = Vector2.new(0, 0), Position = UDim2.new(0, 0, 0, 38), Size = UDim2.new(1, 0, 0, 5), BackgroundColor3 = Theme.ToggleOff, Parent = row })
		corner(3, track)
		local fill = new("Frame", { BackgroundColor3 = Theme.Accent, Parent = track })
		corner(3, fill)
		local function relOf(v) return (v-min)/(max-min) end
		local function redraw()
			fill.Position = UDim2.new(relOf(lo), 0, 0, 0)
			fill.Size = UDim2.new(relOf(hi)-relOf(lo), 0, 1, 0)
			valLbl.Text = lo..suffix.." - "..hi..suffix
			if opts.Callback then opts.Callback(lo, hi) end
			if opts.Flag then SaveManager:Mark(opts.Flag) end
		end
		local function makeKnob(getter)
			local k = new("Frame", { AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(relOf(getter()),0,0.5,0),
				Size = UDim2.new(0,12,0,12), BackgroundColor3 = Theme.Accent, Parent = track })
			corner(6, k)
			return k
		end
		local kLo = makeKnob(function() return lo end)
		local kHi = makeKnob(function() return hi end)
		redraw()
		local drag
		local function bind(knob, isLo)
			knob.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = isLo and "lo" or "hi" end
			end)
		end
		bind(kLo, true) bind(kHi, false)
		UserInputService.InputChanged:Connect(function(i)
			if not drag then return end
			if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
				local rel = math.clamp((i.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
				local v = math.floor((min + (max-min)*rel)+0.5)
				if drag == "lo" then lo = math.min(v, hi) kLo.Position = UDim2.new(relOf(lo),0,0.5,0)
				else hi = math.max(v, lo) kHi.Position = UDim2.new(relOf(hi),0,0.5,0) end
				redraw()
			end
		end)
		UserInputService.InputEnded:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = nil end
		end)
		local function setRange(a, b)
			lo = math.clamp(math.floor((tonumber(a) or lo) + 0.5), min, max)
			hi = math.clamp(math.floor((tonumber(b) or hi) + 0.5), min, max)
			if lo > hi then lo, hi = hi, lo end
			kLo.Position = UDim2.new(relOf(lo), 0, 0.5, 0)
			kHi.Position = UDim2.new(relOf(hi), 0, 0.5, 0)
			redraw()
		end
		local _h = { Get = function() return lo, hi end, Set = setRange }
		if opts.Flag then SaveManager:Bind(opts.Flag, _h, "range") end
		return _h
	end

	function E:CreateDropdown(opts)
		opts = opts or {}
		local options = opts.Options or {}
		local current = opts.Default
		local open = false
		local row = baseRow()
		row.ClipsDescendants = true
		local head = new("TextButton", { Size = UDim2.new(1,0,0,38), BackgroundTransparency = 1, Text = "", Parent = row })
		new("TextLabel", { Size = UDim2.new(1,-20,1,0), BackgroundTransparency = 1, Font = FONT,
