--========================================================
-- HELPERS
--========================================================
local function new(class, props, children)
	local inst = Instance.new(class)
	for k, v in pairs(props or {}) do inst[k] = v end
	for _, c in ipairs(children or {}) do c.Parent = inst end
	return inst
end

local function corner(r, parent)
	return new("UICorner", { CornerRadius = UDim.new(0, r or 8), Parent = parent })
end

local function stroke(parent, color, thickness, transparency)
	return new("UIStroke", {
		Color = color or Theme.Stroke,
		Thickness = thickness or 1,
		Transparency = transparency or 0,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		Parent = parent,
	})
end

local function pad(parent, t, b, l, r)
	return new("UIPadding", {
		PaddingTop = UDim.new(0, t or 0),
		PaddingBottom = UDim.new(0, b or t or 0),
		PaddingLeft = UDim.new(0, l or t or 0),
		PaddingRight = UDim.new(0, r or l or t or 0),
		Parent = parent,
	})
end

local function vlist(parent, padding, align)
	return new("UIListLayout", {
		Padding = UDim.new(0, padding or 8),
		FillDirection = Enum.FillDirection.Vertical,
		HorizontalAlignment = align or Enum.HorizontalAlignment.Left,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = parent,
	})
end

local function tween(inst, time, goal, style, dir)
	local info = TweenInfo.new(time or 0.18, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out)
	local t = TweenService:Create(inst, info, goal)
	t:Play()
	return t
end

local function makeDraggable(frame, handle)
	handle = handle or frame
	local dragging, dragStart, startPos
	-- keep the window on-screen so the header is always grabbable (never stuck off-screen)
	local function applyClamp()
		local cam = workspace.CurrentCamera
		if not cam then return end
		local vp = cam.ViewportSize
		local abs = frame.AbsoluteSize
		local sx, sy = frame.Position.X.Scale, frame.Position.Y.Scale
		local centerX = sx * vp.X + frame.Position.X.Offset
		local centerY = sy * vp.Y + frame.Position.Y.Offset
		local tlX = centerX - abs.X / 2
		local tlY = centerY - abs.Y / 2
		local margin = 90
		tlX = math.clamp(tlX, margin - abs.X, vp.X - margin)
		-- allow dragging the window much lower (under) while keeping the header grabbable
		tlY = math.clamp(tlY, 0, math.max(0, vp.Y - 44))
		centerX = tlX + abs.X / 2
		centerY = tlY + abs.Y / 2
		frame.Position = UDim2.new(sx, centerX - sx * vp.X, sy, centerY - sy * vp.Y)
	end
	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y)
			applyClamp()
		end
	end)
	-- re-clamp if the screen is resized while the window sits near an edge
	if workspace.CurrentCamera then
		workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(applyClamp)
	end
end

-- ============================================================
-- CONFIGURATION SAVING (Flags) — ported feature, NEXO style
-- ============================================================
local SaveManager = {
	Enabled = false,
	Folder = "NexoUI",
	FileName = "config",
	Binds = {},
}
local function _smPath()
	return SaveManager.Folder .. "/" .. SaveManager.FileName .. ".json"
end
function SaveManager:Bind(flag, handle, kind)
	if not flag then return end
	self.Binds[flag] = { handle = handle, kind = kind or "value" }
end
function SaveManager:Save()
	if not self.Enabled then return end
	local data = {}
	for flag, b in pairs(self.Binds) do
		local ok, val = pcall(function() return b.handle.Get() end)
		if ok then
			if b.kind == "color" and typeof(val) == "Color3" then
				data[flag] = string.format("#%02X%02X%02X", math.floor(val.R*255+0.5), math.floor(val.G*255+0.5), math.floor(val.B*255+0.5))
			elseif b.kind == "range" then
				local lo, hi = b.handle.Get()
				data[flag] = { lo, hi }
			else
				data[flag] = val
			end
		end
	end
	pcall(function()
		if typeof(makefolder) == "function" and typeof(isfolder) == "function" and not isfolder(self.Folder) then
			makefolder(self.Folder)
		end
		if typeof(writefile) == "function" then
			writefile(_smPath(), game:GetService("HttpService"):JSONEncode(data))
		end
	end)
end
function SaveManager:Mark(flag)
	if self.Enabled then self:Save() end
end
function SaveManager:Load()
	if not self.Enabled then return end
	local content
	pcall(function()
		if typeof(isfile) == "function" and typeof(readfile) == "function" and isfile(_smPath()) then
			content = readfile(_smPath())
		end
	end)
	if not content then return end
	local ok, data = pcall(function() return game:GetService("HttpService"):JSONDecode(content) end)
	if not ok or type(data) ~= "table" then return end
	for flag, val in pairs(data) do
		local b = self.Binds[flag]
		if b and b.handle and b.handle.Set then
			pcall(function()
				if b.kind == "color" and type(val) == "string" then
					local r = tonumber(string.sub(val,2,3),16) or 255
					local g = tonumber(string.sub(val,4,5),16) or 255
					local bl = tonumber(string.sub(val,6,7),16) or 255
					b.handle.Set(Color3.fromRGB(r, g, bl))
				elseif b.kind == "range" and type(val) == "table" then
					b.handle.Set(val[1], val[2])
				else
					b.handle.Set(val)
				end
			end)
		end
	end
end

--========================================================
-- STARFIELD (procedural galaxy background)
--========================================================
local function createStarfield(parent, count, zBase, cornerR)
	zBase = zBase or 0
	local holder = new("Frame", {
		Name = "Starfield",
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = cornerR and UDim2.new(1, -6, 1, -6) or UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		ClipsDescendants = true,
		ZIndex = zBase,
		Parent = parent,
	})
	if cornerR then corner(cornerR, holder) end

	if hasAsset(ASSETS.StarTexture) then
		local starTex = new("ImageLabel", {
			Size = UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			Image = ASSETS.StarTexture,
			ImageTransparency = 0.2,
			ScaleType = Enum.ScaleType.Crop,
			ZIndex = zBase,
			Parent = holder,
		})
		if cornerR then corner(cornerR, starTex) end
	end

	if hasAsset(ASSETS.HeaderGalaxy) then
		new("ImageLabel", {
			AnchorPoint = Vector2.new(1, 0),
			Position = UDim2.new(1, 40, 0, -40),
			Size = UDim2.new(0, 320, 0, 200),
			BackgroundTransparency = 1,
			Image = ASSETS.HeaderGalaxy,
			ImageTransparency = 0.35,
			ZIndex = zBase,
			Parent = holder,
		})
	end

	local rng = Random.new()
	local stars = {}
	for i = 1, (count or 90) do
		local size = rng:NextInteger(1, 3)
		local star = new("Frame", {
			Position = UDim2.new(rng:NextNumber(), 0, rng:NextNumber(), 0),
			Size = UDim2.new(0, size, 0, size),
			BackgroundColor3 = Color3.fromRGB(255, 255, 255),
			BackgroundTransparency = rng:NextNumber(0.2, 0.85),
			BorderSizePixel = 0,
			ZIndex = zBase,
			Parent = holder,
		})
		corner(size, star)
		stars[i] = {
			inst = star,
			x = star.Position.X.Scale,
			y = star.Position.Y.Scale,
			-- bigger stars drift faster (parallax depth)
			speed = rng:NextNumber(0.012, 0.05) * (0.5 + size / 3),
			phase = rng:NextNumber(0, math.pi * 2),
			twinkle = rng:NextNumber(0.6, 1.6),
			baseT = star.BackgroundTransparency,
		}
	end

	-- ANIMATION: stars drift left + gently twinkle every frame
	local conn
	conn = RunService.RenderStepped:Connect(function(dt)
		if not holder.Parent then conn:Disconnect() return end
		for _, s in ipairs(stars) do
			s.x = s.x - s.speed * dt
			if s.x < -0.02 then
				s.x = 1.02
				s.y = rng:NextNumber()
			end
			s.phase = s.phase + dt * s.twinkle
			local tw = 0.18 * math.sin(s.phase)
			s.inst.Position = UDim2.new(s.x, 0, s.y, 0)
			s.inst.BackgroundTransparency = math.clamp(s.baseT + tw, 0, 1)
		end
	end)

	return holder
end

--========================================================
-- ROOT
--========================================================
local NexoUI = {}
NexoUI.__index = NexoUI

local function getScreenGui()
	-- reuse one ScreenGui for this run (the key system + window share it)
	if NexoUI._activeGui and NexoUI._activeGui.Parent then
		return NexoUI._activeGui
	end
	-- Pick the highest-priority host so the UI stays ON TOP of everything,
	-- including the Roblox ESC / settings menu. gethui()/CoreGui render above
	-- the core menu; PlayerGui is only used as a last-resort fallback.
	local parentGui
	pcall(function()
		if typeof(gethui) == "function" then parentGui = gethui() end
	end)
	if not parentGui then
		pcall(function()
			if typeof(get_hidden_gui) == "function" then parentGui = get_hidden_gui() end
		end)
	end
	if not parentGui then
		pcall(function() parentGui = game:GetService("CoreGui") end)
	end
	if not parentGui then
		parentGui = LocalPlayer:FindFirstChild("PlayerGui")
			or LocalPlayer:WaitForChild("PlayerGui")
	end
	-- ALREADY LOADED? remove any NexoUI left over from a previous execution so
	-- we never stack a duplicate UI on top of the old one (re-run = refresh).
	if parentGui then
		for _, gui in ipairs(parentGui:GetChildren()) do
			if gui:IsA("ScreenGui") and gui.Name == "NexoUI" then gui:Destroy() end
		end
	end
	NexoUI._activeGui = new("ScreenGui", {
		Name = "NexoUI",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		IgnoreGuiInset = true,
		DisplayOrder = 2147483647, -- max: render above the ESC menu and other GUIs
		Parent = parentGui,
	})
	-- protect the GUI from anti-cheat detaching it (Synapse-style executors)
	pcall(function()
		if syn and syn.protect_gui then syn.protect_gui(NexoUI._activeGui) end
	end)
	return NexoUI._activeGui
end

