local NOTIFY_STYLES = {
	Success = { color = Theme.Success, glyph = "\u{2713}" },
	Info    = { color = Theme.Info,    glyph = "i" },
	Warning = { color = Theme.Warning, glyph = "!" },
	Error   = { color = Theme.Error,   glyph = "\u{2715}" },
