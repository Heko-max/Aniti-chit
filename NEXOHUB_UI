		BackgroundColor3 = Theme.Accent,
		AutoButtonColor = false,
		Font = FONT_BOLD,
		Text = "CHECK KEY",
		TextColor3 = Color3.fromRGB(12, 12, 15),
		TextSize = 13,
		ZIndex = 83,
		Parent = card,
	})
	corner(8, checkBtn)

	-- get key / close button
	local getBtn = new("TextButton", {
		AnchorPoint = Vector2.new(0.5, 0),
		Position = UDim2.new(0.5, 0, 0, 258),
		Size = UDim2.new(1, -56, 0, 30),
		BackgroundTransparency = 1,
		AutoButtonColor = false,
		Font = FONT_MED,
		Text = link and "GET KEY" or "CLOSE",
		TextColor3 = Theme.SubText,
		TextSize = 12,
		ZIndex = 83,
		Parent = card,
	})
	corner(8, getBtn)
	stroke(getBtn, Theme.StrokeLight, 1)

