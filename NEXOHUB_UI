--[[
	NEXO UI Library — a self-contained Roblox UI library
	Black starfield theme, white accent. Single file, paste-and-run (executor or LocalScript).

	Basic usage:
		local Nexo = loadstring(...)()   -- or require(this module)
		local Window = Nexo:CreateWindow({ Title = "NEXO UI", SubTitle = "UI LIBRARY", Tagline = "Built for developers." })
		local Home = Window:CreateTab("Home", ICONS.Home)
		local g = Home:CreateGroup({ Title = "BUTTONS" })
		g:CreateButton({ Title = "PRIMARY BUTTON", Variant = "Primary", Callback = function() end })

	New in this build: CreateSection, CreateDivider, CreateParagraph, CreateColorPicker,
	configuration saving (per-element Flag + Window:SaveConfiguration / LoadConfiguration),
	and Window:SetVisibility / IsVisible / Destroy.
]]

