local function scramble(finalText, color)
    status.TextColor3 = color; ghostA.Text = finalText; ghostB.Text = finalText
    local steps = 8
    for s = 1, steps do
        task.delay(s * 0.03, function()
            local out = {}
            for i = 1, #finalText do
                if s/steps > (i/#finalText) then out[i] = finalText:sub(i,i)
                else local r = math.random(#CH); out[i] = CH:sub(r,r) end
            end
            status.Text = table.concat(out)
        end)
    end
    task.delay(steps * 0.03 + 0.02, function() status.Text = finalText end)
end

