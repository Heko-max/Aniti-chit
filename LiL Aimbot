    laserStroke.Color = c; ringFS.Color = c; ringS.Color = c
    dot.BackgroundColor3 = c; scan.BackgroundColor3 = c; status.TextColor3 = c
    for _, t in ipairs(ticks) do t.BackgroundColor3 = c end
