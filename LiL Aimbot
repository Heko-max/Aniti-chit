local function switchGlitch(c)
    for i = 1, math.random(8, 14) do
        local g = Instance.new("Frame")
        g.AnchorPoint = Vector2.new(0.5, 0.5)
        g.Position = UDim2.fromScale(0.5, math.random(0, 100)/100)
        g.Size = UDim2.new(1, math.random(-4, 10), 0, math.random(1, 4))
        local roll = math.random()
        g.BackgroundColor3 = (roll < 0.4) and c
            or (roll < 0.7) and Color3.fromRGB(0,255,255)
            or Color3.fromRGB(255,0,160)
        g.BackgroundTransparency = math.random(0, 4)/10
        g.BorderSizePixel = 0
        g.ZIndex = 6
        g.Parent = btn
        TweenService:Create(g, TweenInfo.new(math.random(15, 30)/100), { BackgroundTransparency = 1 }):Play()
