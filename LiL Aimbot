local function setOnState(instant)
    local ti = TweenInfo.new(instant and 0 or 0.3, Enum.EasingStyle.Back)
    TweenService:Create(btn, ti, { Size = UDim2.fromOffset(52, 52) }):Play()
    laserStroke.Thickness = 3
    setColor(GREEN); switchGlitch(GREEN)
    if instant then status.Text = TXT_ON; ghostA.Text = TXT_ON; ghostB.Text = TXT_ON
    else scramble(TXT_ON, GREEN) end
    if pulseConn then pulseConn:Disconnect(); pulseConn = nil end
    ringFrame.Size = UDim2.fromOffset(62, 62)
end

local function setOffState(instant)
    local ti = TweenInfo.new(instant and 0 or 0.3, Enum.EasingStyle.Quad)
    TweenService:Create(btn, ti, { Size = UDim2.fromOffset(46, 46) }):Play()
    laserStroke.Thickness = 2
    setColor(RED); switchGlitch(RED)
    if instant then status.Text = TXT_OFF; ghostA.Text = TXT_OFF; ghostB.Text = TXT_OFF
    else scramble(TXT_OFF, RED) end
    if pulseConn then pulseConn:Disconnect() end
    pulseConn = RunService.RenderStepped:Connect(function()
        local s = math.sin(tick() * 1.4) * 0.5 + 0.5
        ringFrame.Size = UDim2.fromOffset(52 + s * 16, 52 + s * 16)
    end)
end

-- Denied "shake + glitch" when trying to turn on with no target.
local function denyToggle()
