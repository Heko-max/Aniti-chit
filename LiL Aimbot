    local t = (now * (isOn and 2.0 or 1.3)) % 1
    scan.Position = UDim2.fromScale(0.5, 0.12 + t * 0.76)
    scan.BackgroundTransparency = 0.2 + math.abs(math.sin(now*9)) * 0.4

    local jx = math.sin(now*30) * 2.4 + math.random(-3, 3)
    local jy = math.random(-1, 1)
    ghostA.Position = UDim2.fromScale(0.5 + jx/120, 0.5 + jy/60)
    ghostB.Position = UDim2.fromScale(0.5 - jx/120, 0.5 - jy/60)
    if math.random() < 0.15 then
        ghostA.TextTransparency = math.random(2, 6)/10
        ghostB.TextTransparency = math.random(2, 6)/10
    else
        ghostA.TextTransparency = 0.45
        ghostB.TextTransparency = 0.45
    end

    local flick = (math.random() < 0.18) and math.random(3, 7)/10 or 0
    laserStroke.Transparency = flick
    status.TextTransparency = flick

    if math.random() < 0.12 then
        local base = isOn and TXT_ON or TXT_OFF
        if #base > 0 then
            local i = math.random(#base)
            local r = math.random(#CH)
            status.Text = base:sub(1, i-1) .. CH:sub(r, r) .. base:sub(i+1)
            task.delay(0.05, function() if status.Text ~= base then status.Text = base end end)
        end
    end

    if now >= nextShake then
        nextShake = now + math.random(40, 120)/100
        local sx, sy = math.random(-2, 2), math.random(-2, 2)
        logo.Position = UDim2.new(0.5, sx, 0.5, sy)
        TweenService:Create(logo, TweenInfo.new(0.12, Enum.EasingStyle.Elastic),
            { Position = UDim2.fromScale(0.5, 0.5) }):Play()
    end

    if now >= nextGlitch then
        nextGlitch = now + math.random(50, 150)/100
        glitchBurst(isOn and GREEN or RED, math.random(5, 11))
        if math.random() < 0.5 then
            scramble(isOn and TXT_ON or TXT_OFF, isOn and GREEN or RED)
        end
    end
end)

