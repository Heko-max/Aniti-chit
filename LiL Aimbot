end

--====================================================
--  AIMBOT / CAMLOCK LOGIC
--====================================================
local Prediction = 0.1768521
local enemy = nil
local highlightInstance = nil
local camlockConnection = nil

local function removeHighlight(target)
    if target and target.Character then
        for _, v in ipairs(target.Character:GetChildren()) do
            if v:IsA("Highlight") and v.Name == "CTT_Highlight" then v:Destroy() end
        end
    end
end

local function createHighlight(target)
    if target and target.Character then
        removeHighlight(target)
        local highlight = Instance.new("Highlight")
        highlight.Name = "CTT_Highlight"
        highlight.Adornee = target.Character
        highlight.FillColor = RED
        highlight.OutlineColor = Color3.new(1, 0, 0)
        highlight.FillTransparency = 0.4
        highlight.OutlineTransparency = 0
        highlight.Parent = target.Character
        return highlight
    end
end

local function FindNearestTarget()
    local ClosestDistance, ClosestPlayer = math.huge, nil
    local res = GuiService:GetScreenResolution()
    local Center = Vector2.new(res.X / 2, res.Y / 2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if isTargetable(plr) and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
                if onScreen then
                    local dist = (Center - Vector2.new(pos.X, pos.Y)).Magnitude
                    if dist < ClosestDistance then
                        ClosestDistance = dist
                        ClosestPlayer = plr
                    end
                end
            end
        end
    end
    return ClosestPlayer
end

local function unlockTarget()
    if camlockConnection then camlockConnection:Disconnect(); camlockConnection = nil end
    if highlightInstance then removeHighlight(enemy); highlightInstance = nil end
    enemy = nil
end

-- Returns true if a target was locked. Notifies GREEN on success.
local function lockTarget(preTarget)
    unlockTarget()
    enemy = preTarget or FindNearestTarget()
    if enemy then
        highlightInstance = createHighlight(enemy)
        notify("TARGET LOCKED", "[+] " .. enemy.DisplayName, GREEN)
        camlockConnection = RunService.Heartbeat:Connect(function()
            if enemy and isTargetable(enemy) and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart") then
                local targetPart = enemy.Character.HumanoidRootPart
                local camera = workspace.CurrentCamera
                local predictedPos = targetPart.Position + (targetPart.AssemblyLinearVelocity * Prediction)
                camera.CFrame = CFrame.new(camera.CFrame.Position, predictedPos)
            else
                unlockTarget()
            end
        end)
        return true
    end
    return false
end

