    local ox = container.Position.X.Offset
    for i = 1, 4 do
        task.delay((i-1) * 0.04, function()
            container.Position = UDim2.new(container.Position.X.Scale, ox + ((i % 2 == 0) and 6 or -6),
                container.Position.Y.Scale, container.Position.Y.Offset)
        end)
    end
    task.delay(0.2, function()
        container.Position = UDim2.new(container.Position.X.Scale, ox,
            container.Position.Y.Scale, container.Position.Y.Offset)
    end)
end

