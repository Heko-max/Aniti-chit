    knob.AutoButtonColor = false
    knob.BackgroundColor3 = currentAccent
    knob.BorderSizePixel = 0
    knob.Parent = track
    local knc = Instance.new("UICorner"); knc.CornerRadius = UDim.new(1, 0); knc.Parent = knob

