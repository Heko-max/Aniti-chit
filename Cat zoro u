                local t = math.random(26, 46) / 10
                TweenService:Create(cloud, TweenInfo.new(t, Enum.EasingStyle.Sine), { ImageTransparency = 0.45 }):Play()
                task.wait(t)
                TweenService:Create(cloud, TweenInfo.new(t, Enum.EasingStyle.Sine), { ImageTransparency = 0.72 }):Play()
                task.wait(t)
