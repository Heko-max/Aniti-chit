-- Hacker-theme "Matrix rain": green code glyphs continuously falling down the background.
local function makeMatrix(parent, corner, columnCount)
    local mx = Instance.new("Frame")
    mx.Name = "Matrix"
    mx.Size = UDim2.new(1, 0, 1, 0)
    mx.BackgroundColor3 = Color3.fromRGB(0, 6, 0)
    mx.BorderSizePixel = 0
    mx.ClipsDescendants = true
    mx.ZIndex = 0
    mx.Parent = parent

    local mxCorner = Instance.new("UICorner")
    mxCorner.CornerRadius = corner or UDim.new(0, 12)
    mxCorner.Parent = mx

    local CHARS = "0123456789ABCDEFGHJKLMNPQRSTUVWXYZ<>*/+=:#%@"
    local function randChar()
        local i = math.random(1, #CHARS)
        return CHARS:sub(i, i)
    end
    local function buildStream(n)
        local parts = {}
        for _ = 1, n do parts[#parts + 1] = randChar() end
        return table.concat(parts, "\n")
    end

    local cols = columnCount or 16
    local colW = 14
    for i = 1, cols do
        local col = Instance.new("TextLabel")
        col.Name = "Stream"
        col.BackgroundTransparency = 1
        col.Size = UDim2.new(0, colW, 2, 0)
        col.Position = UDim2.new(0, (i - 1) * colW, 0, 0)
        col.Font = Enum.Font.Code
        col.TextSize = 12
        col.TextColor3 = currentAccent
        col.TextXAlignment = Enum.TextXAlignment.Center
        col.TextYAlignment = Enum.TextYAlignment.Top
        col.ZIndex = 1
        col.Parent = mx

        -- fade the trail (transparency only; colour comes from the theme via TextColor3)
        local g = Instance.new("UIGradient")
        g.Rotation = 90
        g.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0.00, 0.7),
            NumberSequenceKeypoint.new(0.70, 0.15),
            NumberSequenceKeypoint.new(1.00, 0.0),
        })
        g.Parent = col

        task.spawn(function()
            -- staggered start so the background fills in gradually (not all at once)
            task.wait(math.random(0, 45) / 10)
            while col.Parent do
                if matrixFling then
                    -- hidden during the fling; individual letters do the flying instead
                    col.Visible = false
                    task.wait(0.05)
                else
                    col.Visible = true
                    col.Rotation = 0
                    col.Text = buildStream(16)
                    col.Position = UDim2.new(0, (i - 1) * colW, 0, -math.random(120, 260))
                    local fall = TweenService:Create(
                        col,
                        TweenInfo.new(math.random(55, 100) / 10, Enum.EasingStyle.Linear),
                        { Position = UDim2.new(0, (i - 1) * colW, 1, 30) }
                    )
                    fall:Play()
                    while fall.PlaybackState == Enum.PlaybackState.Playing and not matrixFling do
                        task.wait(0.1)
                    end
                    if matrixFling then fall:Cancel() end
                    task.wait(math.random(3, 9) / 10)
                end
            end
        end)
    end

    return mx
end

