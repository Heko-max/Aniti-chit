--// ===== Responsive scaling (PC, laptop, Mac, phone, iPhone, tablet, console) =====
local camera = workspace.CurrentCamera
local responsiveScale = 1
local function computeScale()
    local vp = (camera and camera.ViewportSize) or Vector2.new(1366, 768)
    if vp.X < 1 or vp.Y < 1 then vp = Vector2.new(1366, 768) end
    -- scale against a 1366x768 laptop reference screen
    local s = math.min(vp.X / 1366, vp.Y / 768)
    -- touch-only devices (phones / tablets) get a slightly larger UI so controls stay tappable
    if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
        s = s * 1.15
    end
    return math.clamp(s, 0.8, 1.7)
end
responsiveScale = computeScale()

-- Animated "laser" highlight that travels around any UIStroke.
local function addLaserStroke(stroke, speed)
    local grad = Instance.new("UIGradient")
    -- greyscale travelling highlight; the UIStroke.Color (theme colour) tints it
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0.00, Color3.fromRGB(25, 25, 25)),
        ColorSequenceKeypoint.new(0.40, Color3.fromRGB(120, 120, 120)),
        ColorSequenceKeypoint.new(0.50, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(0.60, Color3.fromRGB(120, 120, 120)),
        ColorSequenceKeypoint.new(1.00, Color3.fromRGB(25, 25, 25)),
    })
    grad.Rotation = 0
    grad.Parent = stroke
    TweenService:Create(
        grad,
        TweenInfo.new(speed or 2.2, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1),
        { Rotation = 360 }
    ):Play()
    return grad
end

