-- Retint the whole UI to a target accent colour (with a dim variant for tracks / inactive tabs).
local function applyTheme(accent, time)
    currentAccent = accent
    currentDim = Color3.new(accent.R * 0.18, accent.G * 0.18, accent.B * 0.18)
    local ti = TweenInfo.new(time or 0.8, Enum.EasingStyle.Sine)

    -- static themed elements
    TweenService:Create(ms,         ti, { Color = accent }):Play()
    TweenService:Create(miniStroke, ti, { Color = accent }):Play()
    TweenService:Create(glow,       ti, { ImageColor3 = accent }):Play()
    TweenService:Create(titleLbl,   ti, { TextColor3 = accent }):Play()
    TweenService:Create(divider,    ti, { BackgroundColor3 = accent }):Play()
    TweenService:Create(switchHolder, ti, { ScrollBarImageColor3 = accent }):Play()

    -- matrix code-rain columns
    for _, d in ipairs(matrix:GetDescendants()) do
        if d:IsA("TextLabel") then
            TweenService:Create(d, ti, { TextColor3 = accent }):Play()
        end
    end

    -- live tabs + switches (use the same slow tween so they change colour together with everything else)
    themeTweenTime = time or 0.8
    updateTabVisual()
    for _, fn in ipairs(switchRefreshers) do
        fn()
    end
    themeTweenTime = 0.15
end

-- Glitch sequence: scramble all text -> shake -> sudden 1s blackout -> (caller tweens colour).
local GLITCH_CHARS = "01001011<>#%@/\\|=+*?ABCDEF9824XZ"
local function scrambleText(len)
    local t = {}
    for _ = 1, math.max(2, len) do
        local i = math.random(1, #GLITCH_CHARS)
        t[#t + 1] = GLITCH_CHARS:sub(i, i)
    end
    return table.concat(t)
end

local function glitchMain()
    -- snapshot the panel's text so we can restore it after the corruption
    local labels = {}
    for _, d in ipairs(main:GetDescendants()) do
        if (d:IsA("TextLabel") or d:IsA("TextButton")) and d.Name ~= "Stream" and #d.Text > 0 then
            labels[#labels + 1] = { obj = d, text = d.Text }
        end
    end

    -- PHASE 1: glitch every number & letter (rapid scramble) ~3.5s
    for _ = 1, 70 do
        for _, e in ipairs(labels) do
            e.obj.Text = scrambleText(#e.text)
        end
        task.wait(0.05)
    end

    -- PHASE 2: shaking + the background text breaks apart and flies around letter-by-letter ~5.5s
    matrix.ClipsDescendants = false
    matrixFling = true

    -- spawn single-character "particles" that peel off and fly around one-by-one
    local FLY = "01ABXZKLMN#%@<>*/=0189"
    local flinging = true
    local particles = {}
    for _ = 1, 80 do
        task.spawn(function()
            task.wait(math.random(0, 200) / 100)  -- staggered so letters leave one-by-one
            if not flinging then return end
            local k = math.random(1, #FLY)
            local ch = Instance.new("TextLabel")
            ch.Name = "FlingChar"
            ch.BackgroundTransparency = 1
            ch.Size = UDim2.fromOffset(16, 18)
            ch.Font = Enum.Font.Code
            ch.TextSize = 13
            ch.TextColor3 = currentAccent
            ch.Text = FLY:sub(k, k)
            ch.Position = UDim2.fromScale(math.random(20, 80) / 100, math.random(20, 80) / 100)
            ch.ZIndex = 2
            ch.Parent = matrix
            particles[#particles + 1] = ch
            while flinging do
                local tw = TweenService:Create(ch, TweenInfo.new(math.random(4, 9) / 10, Enum.EasingStyle.Quad), {
                    Position = UDim2.fromScale(math.random(-30, 130) / 100, math.random(-50, 150) / 100),
                    Rotation = math.random(-180, 180),
                })
                tw:Play()
                tw.Completed:Wait()
            end
        end)
    end

    -- ERROR 404 warning that pops up (flashing red) for the last ~3s before the blackout
    local errorWarn
    task.spawn(function()
        task.wait(2.5)
        if not flinging then return end
        local w = Instance.new("Frame")
        w.Name = "Error404"
        w.AnchorPoint = Vector2.new(0.5, 0.5)
        w.Position = UDim2.fromScale(0.5, 0.5)
        w.Size = UDim2.fromOffset(190, 84)
        w.BackgroundColor3 = Color3.fromRGB(26, 22, 0)
        w.BackgroundTransparency = 0.08
        w.ZIndex = 50
        w.Parent = main
        local wc = Instance.new("UICorner"); wc.CornerRadius = UDim.new(0, 8); wc.Parent = w
        local wstk = Instance.new("UIStroke"); wstk.Color = Color3.fromRGB(255, 210, 30); wstk.Thickness = 2.5; wstk.Parent = w
        local wt = Instance.new("TextLabel")
        wt.BackgroundTransparency = 1
        wt.Size = UDim2.fromScale(1, 1)
        wt.Font = Enum.Font.Code
        wt.TextSize = 20
        wt.TextColor3 = Color3.fromRGB(255, 215, 40)
        wt.Text = "⚠ ERROR 404\n! WARNING !"
        wt.ZIndex = 51
        wt.Parent = w
        errorWarn = w
        while w.Parent do
            local off = (wt.TextTransparency > 0.3) and 0 or 0.65
            wt.TextTransparency = off
            wstk.Transparency = off
            w.BackgroundTransparency = 0.08 + off * 0.35
            task.wait(0.16)
        end
    end)

    local base = main.Position
    for _ = 1, 137 do
        main.Position = base + UDim2.fromOffset(math.random(-16, 16), math.random(-14, 14))
        -- (no rotation: Roblox clipping breaks while rotated, which let the switches leak out of the UI)
        ms.Transparency = math.random(0, 80) / 100
        for _, e in ipairs(labels) do
            e.obj.Text = scrambleText(#e.text)
        end
        task.wait(0.04)
    end
    main.Position = base
    main.Rotation = 0
    ms.Transparency = 0.15

    -- stop & clean up the flying letters + the error popup
    flinging = false
    if errorWarn then errorWarn:Destroy() end
    for _, p in ipairs(particles) do
        p:Destroy()
    end
    matrixFling = false
    matrix.ClipsDescendants = true

    -- restore the real text
    for _, e in ipairs(labels) do
        e.obj.Text = e.text
    end

    -- (no blackout) the glitch ends here; the caller eases straight into the new colour
end

-- Every random interval (always under 1 minute): glitch, then tween into the other colour.
task.spawn(function()
    local nextColor = RED  -- starts green; first flip goes to red
    while gui.Parent do
        task.wait(math.random(22, 55))
        glitchMain()

        -- FAST: shrink the whole UI away (disappear)
        TweenService:Create(uiScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Scale = 0 }):Play()
        TweenService:Create(miniScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Scale = 0 }):Play()
        task.wait(0.22)

        -- swap to the new colour while it's hidden
        applyTheme(nextColor, 0.4)

        -- SLOW: bring the whole UI back in (appear)
        TweenService:Create(uiScale, TweenInfo.new(2.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Scale = responsiveScale }):Play()
        TweenService:Create(miniScale, TweenInfo.new(2.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Scale = responsiveScale }):Play()

        nextColor = (nextColor == RED) and GREEN or RED
    end
end)
