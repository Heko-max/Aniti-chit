    local names = TAB_SWITCHES[TAB_NAMES[tabIndex]] or {}
    local order = 0
    order += 1; makeSection("TOGGLES", order)
    for _, n in ipairs(names) do
        order += 1; makeSwitch(n, order)
    end
    order += 1; makeSection("OPTIONS", order)
    order += 1; makeSlider("Aim Smoothness", order)
    order += 1; makeButton("Execute", order)
    switchHolder.CanvasPosition = Vector2.new(0, 0)
end

