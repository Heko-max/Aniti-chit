local function makeSwitch(name, order)
    local row = Instance.new("Frame")
    row.Name = "Switch_" .. name
    row.LayoutOrder = order
    row.Size = UDim2.new(1, 0, 0, 28)
    row.BackgroundTransparency = 1
    row.Parent = switchHolder

    local rowLabel = Instance.new("TextLabel")
    rowLabel.BackgroundTransparency = 1
    rowLabel.Size = UDim2.new(1, -56, 1, 0)
    rowLabel.Font = Enum.Font.Michroma
    rowLabel.Text = name
    rowLabel.TextSize = 12
    rowLabel.TextColor3 = WHITE
    rowLabel.TextXAlignment = Enum.TextXAlignment.Left
    rowLabel.TextTruncate = Enum.TextTruncate.AtEnd
    rowLabel.Parent = row

    local track = Instance.new("TextButton")
    track.Size = UDim2.new(0, 46, 0, 24)
    track.Position = UDim2.new(1, -46, 0.5, -12)
    track.AutoButtonColor = false
    track.Text = ""
    track.BackgroundColor3 = DIM
    track.BorderSizePixel = 0
    track.Parent = row
    local tc = Instance.new("UICorner"); tc.CornerRadius = UDim.new(1, 0); tc.Parent = track
    local tstroke = Instance.new("UIStroke"); tstroke.Color = WHITE; tstroke.Transparency = 0.4; tstroke.Parent = track

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0, 3, 0.5, -9)
    knob.BackgroundColor3 = WHITE
    knob.BorderSizePixel = 0
    knob.Parent = track
    local kc = Instance.new("UICorner"); kc.CornerRadius = UDim.new(1, 0); kc.Parent = knob

    local on = false
    local function refresh()
        TweenService:Create(rowLabel, TweenInfo.new(themeTweenTime), { TextColor3 = currentAccent }):Play()
        TweenService:Create(tstroke, TweenInfo.new(themeTweenTime), { Color = currentAccent }):Play()
        if on then
            TweenService:Create(track, TweenInfo.new(themeTweenTime), { BackgroundColor3 = currentAccent }):Play()
            TweenService:Create(knob, TweenInfo.new(0.15), { Position = UDim2.new(1, -21, 0.5, -9) }):Play()
            TweenService:Create(knob, TweenInfo.new(themeTweenTime), { BackgroundColor3 = BLACK }):Play()
        else
            TweenService:Create(track, TweenInfo.new(themeTweenTime), { BackgroundColor3 = currentDim }):Play()
            TweenService:Create(knob, TweenInfo.new(0.15), { Position = UDim2.new(0, 3, 0.5, -9) }):Play()
            TweenService:Create(knob, TweenInfo.new(themeTweenTime), { BackgroundColor3 = currentAccent }):Play()
        end
    end
    table.insert(switchRefreshers, refresh)
    refresh()

    track.MouseEnter:Connect(function()
        TweenService:Create(tstroke, TweenInfo.new(0.15), { Transparency = 0 }):Play()
    end)
    track.MouseLeave:Connect(function()
        TweenService:Create(tstroke, TweenInfo.new(0.15), { Transparency = 0.4 }):Play()
    end)
    track.MouseButton1Click:Connect(function()
        on = not on
        refresh()
    end)
end

