--// ===== Fruit Fast Attack  (PL7 logic) =====
--// ============================================================
local function getClosestEnemy(distance)
    local target, others = nil, {}
    if Enemies then
        for _, enemy in pairs(Enemies:GetChildren()) do
            local hrp = enemy:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = LocalPlayer:DistanceFromCharacter(hrp.Position)
                if dist < distance then
                    if not target then target = hrp else table.insert(others, { enemy, hrp }) end
                end
            end
        end
    end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = LocalPlayer:DistanceFromCharacter(hrp.Position)
                if dist < distance then
                    if not target then target = hrp else table.insert(others, { plr, hrp }) end
                end
            end
        end
    end
    return target, others
end

local function AttackEnemy(target, tbl)
    if target and RegisterAttack and RegisterHit then
        pcall(function()
            RegisterAttack:FireServer(0)
            RegisterHit:FireServer(target, tbl)
        end)
    end
end

local function AttackNearest()
    pcall(function()
        local target, others = getClosestEnemy(ATTACK_DISTANCE)
        AttackEnemy(target, others)
    end)
end

local function Actived()
    pcall(function()
        local tool = Character and Character:FindFirstChildOfClass("Tool")
        if tool and getconnections and getupvalues then
            for _, v in next, getconnections(tool.Activated) do
                if typeof(v.Function) == "function" then getupvalues(v.Function) end
            end
        end
    end)
end

local function AttackM1()
    pcall(function()
        local tool = Character and Character:FindFirstChildOfClass("Tool")
        if not tool then return end
        local LeftClickRemote = tool:FindFirstChild("LeftClickRemote")
        if tool.ToolTip == "Blox Fruit" and LeftClickRemote then
            Actived()
            LeftClickRemote:FireServer(Vector3.new(0.01, -500, 0.01), 1, true)
            LeftClickRemote:FireServer(false)
        end
    end)
end

local function BladeHits()
    AttackNearest()
    AttackM1()
end

local spamEnabled = false
local spamThread = nil
local function startSpam()
    if spamThread then return end
    spamThread = task.spawn(function()
        while spamEnabled do
            pcall(BladeHits)
            if ATTACK_DELAY > 0 then task.wait(ATTACK_DELAY) else task.wait() end
        end
        spamThread = nil
    end)
end

