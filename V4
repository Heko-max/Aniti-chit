local RANGE_MIN, RANGE_MAX = 100, 1000   -- Bring Range (PL7 BringDistance)
local STAND_MIN, STAND_MAX = 1, 50       -- Stand Dist (stack offset in front)
local ATTACK_DISTANCE      = 120         -- PL7 getClosestEnemy distance
local ATTACK_DELAY         = 0           -- PL7 GlobalDelay (0 = full speed)

--// ===== Saved settings =====
local settings = { bring = false, range = 500, front = 2, fruit = false }

local function canFiles()
    return (typeof(writefile) == "function")
        and (typeof(readfile) == "function")
        and (typeof(isfile) == "function")
end

local function loadSettings()
    if not canFiles() then return end
    pcall(function()
        if isfile(SAVE_FILE) then
            local data = HttpService:JSONDecode(readfile(SAVE_FILE))
            if type(data) == "table" then
                if type(data.bring) == "boolean" then settings.bring = data.bring end
                if type(data.fruit) == "boolean" then settings.fruit = data.fruit end
                if type(data.range) == "number" then
                    settings.range = math.clamp(math.floor(data.range), RANGE_MIN, RANGE_MAX)
                end
                if type(data.front) == "number" then
                    settings.front = math.clamp(math.floor(data.front), STAND_MIN, STAND_MAX)
                end
            end
        end
    end)
end

local function saveSettings()
    if not canFiles() then return end
    pcall(function()
        writefile(SAVE_FILE, HttpService:JSONEncode(settings))
    end)
end

loadSettings()

