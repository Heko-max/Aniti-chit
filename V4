local function addLaserStroke(stroke, speed)
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0.00, Color3.fromRGB(35, 35, 35)),
        ColorSequenceKeypoint.new(0.40, Color3.fromRGB(120, 120, 120)),
        ColorSequenceKeypoint.new(0.50, WHITE),
        ColorSequenceKeypoint.new(0.60, Color3.fromRGB(120, 120, 120)),
        ColorSequenceKeypoint.new(1.00, Color3.fromRGB(35, 35, 35)),
    })
    grad.Rotation = 0
    grad.Parent = stroke
    TweenService:Create(
        grad,
        TweenInfo.new(speed or 2.2, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1),
        { Rotation = 360 }
    ):Play()
    return grad
end

local function makeGalaxy(parent, corner, starCount)
    local gx = Instance.new("Frame")
    gx.Name = "Galaxy"
    gx.Size = UDim2.new(1, 0, 1, 0)
    gx.BackgroundColor3 = Color3.fromRGB(6, 4, 18)
    gx.BorderSizePixel = 0
    gx.ClipsDescendants = true
    gx.ZIndex = 0
    gx.Parent = parent

    local gxCorner = Instance.new("UICorner")
    gxCorner.CornerRadius = corner or UDim.new(0, 12)
    gxCorner.Parent = gx

    local neb = Instance.new("UIGradient")
    neb.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0.00, Color3.fromRGB(8, 6, 26)),
        ColorSequenceKeypoint.new(0.30, Color3.fromRGB(42, 18, 74)),
        ColorSequenceKeypoint.new(0.55, Color3.fromRGB(18, 24, 86)),
        ColorSequenceKeypoint.new(0.80, Color3.fromRGB(74, 22, 92)),
        ColorSequenceKeypoint.new(1.00, Color3.fromRGB(6, 4, 18)),
    })
    neb.Rotation = 0
    neb.Parent = gx
    TweenService:Create(neb, TweenInfo.new(9, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), { Rotation = 40 }):Play()

    local clouds = {
        { c = Color3.fromRGB(150, 70, 255), p = UDim2.new(0.24, 0, 0.30, 0) },
        { c = Color3.fromRGB(60, 110, 255), p = UDim2.new(0.72, 0, 0.66, 0) },
    }
    for _, def in ipairs(clouds) do
        local cloud = Instance.new("ImageLabel")
        cloud.Name = "Nebula"
        cloud.BackgroundTransparency = 1
        cloud.Image = "rbxassetid://5028857084"
        cloud.ImageColor3 = def.c
        cloud.ImageTransparency = 0.6
        cloud.ScaleType = Enum.ScaleType.Slice
        cloud.SliceCenter = Rect.new(24, 24, 276, 276)
        cloud.AnchorPoint = Vector2.new(0.5, 0.5)
        cloud.Size = UDim2.new(0, 130, 0, 130)
        cloud.Position = def.p
        cloud.ZIndex = 0
        cloud.Parent = gx
    end

    local stars = {}
    for _ = 1, (starCount or STAR_COUNT) do
        local s = Instance.new("Frame")
        s.Name = "Star"
        local sz = math.random(10, 22) / 10
        s.Size = UDim2.new(0, sz, 0, sz)
        s.Position = UDim2.new(math.random(), 0, math.random(), 0)
        s.BackgroundColor3 = WHITE
        s.BorderSizePixel = 0
        s.BackgroundTransparency = math.random(20, 70) / 100
        s.ZIndex = 1
        local sc = Instance.new("UICorner"); sc.CornerRadius = UDim.new(1, 0); sc.Parent = s
        s.Parent = gx
        stars[#stars + 1] = {
            f = s, drift = math.random(6, 16) / 100,
            phase = math.random() * 6.2831853, tw = math.random(8, 22) / 10,
        }
    end

    local acc = 0
    track(RunService.Heartbeat:Connect(function(dt)
        if not gx.Parent then return end
        acc = acc + dt
        if acc < 1 / 30 then return end
        local step = acc
        acc = 0
        local t = os.clock()
        for _, st in ipairs(stars) do
            local f = st.f
            local px = f.Position.X.Scale - st.drift * step
            if px < -0.05 then px = 1.05 end
            f.Position = UDim2.new(px, 0, f.Position.Y.Scale, 0)
            f.BackgroundTransparency = 0.45 + 0.32 * math.sin(t / st.tw + st.phase)
        end
    end))

    return gx
end

