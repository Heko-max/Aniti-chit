local function doBring()
    if not (Enemies and HumanoidRootPart) then return end
    local stackPos = HumanoidRootPart.CFrame * CFrame.new(0, 0, -settings.front)
    for _, v in pairs(Enemies:GetChildren()) do
        pcall(function()
            local hrp = v:FindFirstChild("HumanoidRootPart")
            local hum = v:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0
               and (hrp.Position - HumanoidRootPart.Position).Magnitude <= settings.range then
                if v.PrimaryPart then v.PrimaryPart.CFrame = stackPos end
                hrp.CFrame = stackPos
                hum.JumpPower = 0
                hum.WalkSpeed = 0
                hrp.Size = Vector3.new(1, 1, 1)
                hrp.Transparency = 1
                hrp.CanCollide = false
                if v:FindFirstChild("Head") then v.Head.CanCollide = false end
                if v.PrimaryPart then v.PrimaryPart.CanCollide = false end
                if hum:FindFirstChild("Animator") then hum.Animator:Destroy() end
                hum:ChangeState(11)
                hum:ChangeState(14)
            end
        end)
    end
end

local bringConn = nil
local function startBring()
    if bringConn then return end
    bringConn = RunService.RenderStepped:Connect(function()
        if settings.bring and gui.Parent then
            pcall(doBring)
        end
    end)
    track(bringConn)
end
local function stopBring()
    if bringConn then bringConn:Disconnect() bringConn = nil end
end

