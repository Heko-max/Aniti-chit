    lbl.Parent = row

    local tbtn = Instance.new("TextButton")
    tbtn.Size = UDim2.new(0, 46, 0, 24)
    tbtn.Position = UDim2.new(1, -46, 0.5, -12)
    tbtn.AutoButtonColor = false
    tbtn.Text = ""
