    tbtn.BorderSizePixel = 0
    tbtn.Parent = row
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1, 0); c.Parent = tbtn
    local st = Instance.new("UIStroke"); st.Color = WHITE; st.Transparency = 0.4; st.Parent = tbtn

    local kn = Instance.new("Frame")
    kn.Size = UDim2.new(0, 18, 0, 18)
    kn.Position = UDim2.new(0, 3, 0.5, -9)
    kn.BackgroundColor3 = WHITE
    kn.BorderSizePixel = 0
    kn.Parent = tbtn
    local knc = Instance.new("UICorner"); knc.CornerRadius = UDim.new(1, 0); knc.Parent = kn

    local function refresh()
        if getState() then
            TweenService:Create(tbtn, TweenInfo.new(0.15), { BackgroundColor3 = WHITE }):Play()
            TweenService:Create(kn, TweenInfo.new(0.15), { Position = UDim2.new(1, -21, 0.5, -9), BackgroundColor3 = BLACK }):Play()
        else
            TweenService:Create(tbtn, TweenInfo.new(0.15), { BackgroundColor3 = DIM }):Play()
            TweenService:Create(kn, TweenInfo.new(0.15), { Position = UDim2.new(0, 3, 0.5, -9), BackgroundColor3 = WHITE }):Play()
        end
    end

    tbtn.MouseEnter:Connect(function()
        TweenService:Create(st, TweenInfo.new(0.15), { Transparency = 0 }):Play()
    end)
    tbtn.MouseLeave:Connect(function()
        TweenService:Create(st, TweenInfo.new(0.15), { Transparency = 0.4 }):Play()
    end)
    tbtn.MouseButton1Click:Connect(function()
        onClick()
        refresh()
    end)

    refresh()
    return { refresh = refresh }
end

--// ===== Reusable slider component =====
local function createSlider(orderLabel, orderBar, labelText, minV, maxV, initial, onChange)
    local lbl = Instance.new("TextLabel")
    lbl.LayoutOrder = orderLabel
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 0, 18)
    lbl.Font = Enum.Font.Michroma
    lbl.TextSize = 12
    lbl.TextColor3 = WHITE
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = content

    local bar = Instance.new("TextButton")
    bar.LayoutOrder = orderBar
    bar.AutoButtonColor = false
    bar.Text = ""
    bar.Size = UDim2.new(1, 0, 0, 12)
    bar.BackgroundColor3 = DIM
    bar.BorderSizePixel = 0
    bar.Parent = content
    local bc = Instance.new("UICorner"); bc.CornerRadius = UDim.new(1, 0); bc.Parent = bar
    local bs = Instance.new("UIStroke"); bs.Color = WHITE; bs.Transparency = 0.5; bs.Parent = bar

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0.1, 0, 1, 0)
    fill.BackgroundColor3 = WHITE
    fill.BorderSizePixel = 0
    fill.Parent = bar
    local fcn = Instance.new("UICorner"); fcn.CornerRadius = UDim.new(1, 0); fcn.Parent = fill

    local sk = Instance.new("Frame")
    sk.Size = UDim2.new(0, 14, 0, 14)
    sk.AnchorPoint = Vector2.new(0.5, 0.5)
    sk.Position = UDim2.new(0.1, 0, 0.5, 0)
    sk.BackgroundColor3 = WHITE
    sk.BorderSizePixel = 0
    sk.ZIndex = 2
    sk.Parent = bar
    local skc = Instance.new("UICorner"); skc.CornerRadius = UDim.new(1, 0); skc.Parent = sk
    local sks = Instance.new("UIStroke"); sks.Color = BLACK; sks.Transparency = 0.3; sks.Parent = sk

    local value = math.clamp(initial, minV, maxV)
    local function refresh()
        local rel = math.clamp((value - minV) / (maxV - minV), 0, 1)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        sk.Position = UDim2.new(rel, 0, 0.5, 0)
        lbl.Text = labelText .. " : " .. value
    end

    local sliding = false
    local function setFromX(absX)
        local barPos  = bar.AbsolutePosition.X
        local barSize = bar.AbsoluteSize.X
        if barSize <= 0 then return end
        local rel = math.clamp((absX - barPos) / barSize, 0, 1)
        value = math.floor(minV + rel * (maxV - minV) + 0.5)
        refresh()
        if onChange then onChange(value, false) end
    end

    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true
            setFromX(input.Position.X)
        end
    end)
    track(UserInputService.InputChanged:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement
           or input.UserInputType == Enum.UserInputType.Touch) then
            setFromX(input.Position.X)
        end
    end))
    track(UserInputService.InputEnded:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch) then
            sliding = false
            if onChange then onChange(value, true) end
        end
    end))

    refresh()
    return { get = function() return value end, set = function(v) value = math.clamp(v, minV, maxV); refresh() end }
end

