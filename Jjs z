-- The quest mob's NAME tag lives on its CLIENT rig (workspace.Characters.Client),
-- NOT the server model we attack. So we read names from client rigs, then match the
-- server NPCs to them by position. This targets ONLY the quest mobs.
-- read the current quest's target enemy from the quest tracker text ("Defeat X (n/m)")
local function questTarget()
    if QUEST_TARGET ~= "" then return QUEST_TARGET end
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if pg then
        for _, d in ipairs(pg:GetDescendants()) do
            if d:IsA("TextLabel") then
                local nm = string.match(d.Text, "([%a%s]+)%s*%(%d+/%d+%)")
                if nm and #nm > 2 then
                    nm = nm:gsub("^%s+", ""):gsub("%s+$", "")
                    nm = nm:gsub("^[Dd]efeat%s+the%s+", ""):gsub("^[Dd]efeat%s+", ""):gsub("^[Kk]ill%s+", ""):gsub("^[Cc]ollect%s+", "")
                    nm = nm:gsub("s$", "") -- singularize (Students -> Student)
                    return nm
                end
            end
        end
    end
    return ""
end
local function questTargetPositions()
    local hits = {}
    local ClientF = workspace.Characters:FindFirstChild("Client")
    local qt = questTarget()
    if not ClientF or qt == "" then return hits end
    local target = string.lower(qt)
    for _, d in ipairs(ClientF:GetDescendants()) do
        if d:IsA("TextLabel") and string.find(string.lower(d.Text), target, 1, true) then
            local rig = d:FindFirstAncestorWhichIsA("Model")
            local hrp = rig and rig:FindFirstChild("HumanoidRootPart")
            if hrp then table.insert(hits, hrp.Position) end
        end
    end
    return hits
end
-- only the server NPCs that belong to the current quest (matched to the named client rigs)
local function collectQuestNPCs()
    local myModel = getModel()
    local myHRP = myModel and myModel:FindFirstChild("HumanoidRootPart")
    if not myHRP or not NPCsF then return {}, nil, nil end
    if questTarget() == "" then return {}, myModel, myHRP end
    local hits = questTargetPositions()
    local targets = {}
    for _, m in ipairs(NPCsF:GetChildren()) do
        if m ~= myModel then
            local h = m:FindFirstChild("HumanoidRootPart")
            local hum = m:FindFirstChildOfClass("Humanoid")
            if h and hum and hum.Health > 0 then
                for _, pos in ipairs(hits) do
                    if (h.Position - pos).Magnitude < 10 then
                        table.insert(targets, m)
                        break
                    end
                end
            end
        end
    end
    return targets, myModel, myHRP
end

-- Fast Quest: snaps ALL quest NPCs to you ONCE per new spawn wave (not a repeating loop).
-- Each NPC model instance is the key; when it dies and a new one spawns, it gets brought again.
local FastQuestOn = false
local fastQuestBrought = {} -- key = NPC model instance, value = Vector3 where it was brought
local fastQuestFrozenPos = nil -- player CFrame held in place during multi-NPC Fast Quest bring

-- Auto Quest runtime CACHE (heavy scans run ~4x/sec, NOT every frame -> fixes lag)
local questNPCs, questMyModel, questMyHRP = {}, nil, nil
task.spawn(function()
    while getgenv().NexoHubSession == SESSION do
        if QuestOn then
            local t, mm, hrp = collectQuestNPCs()
            questNPCs, questMyModel, questMyHRP = t or {}, mm, hrp
            -- Fast Quest: go TO the NPC (Auto Quest tween), then bring once arrived (<=20 studs).
            -- fastQuestBrought[m] = Vector3 of where it was brought (NOT just true).
            -- If it escapes (moves >15 studs from that spot): reset flag so player goes back & re-brings.
            if FastQuestOn and hrp and #questNPCs > 0 then
                -- Step 1: detect escaped/unfrozen NPCs and reset their flag
                for m, broughtPos in pairs(fastQuestBrought) do
                    if not m.Parent then
                        fastQuestBrought[m] = nil -- dead NPC, clean up
                    elseif typeof(broughtPos) == "Vector3" then
                        local h = m:FindFirstChild("HumanoidRootPart")
                        if h and (h.Position - broughtPos).Magnitude > 15 then
                            -- NPC escaped (not taking damage / not frozen) -> go back and re-bring
                            fastQuestBrought[m] = nil
                        end
                    end
                end
                -- Step 2: only bring once player has arrived near a quest NPC
                local arrived = false
                for _, m in ipairs(questNPCs) do
                    local h = m:FindFirstChild("HumanoidRootPart")
                    if h and (h.Position - hrp.Position).Magnitude <= 20 then
                        arrived = true break
                    end
                end
                if arrived then
                    if #questNPCs == 1 then
                        -- Only 1 NPC: teleport PLAYER directly to it instead of bringing it to the player
                        local m = questNPCs[1]
                        if not fastQuestBrought[m] then
                            local h = m:FindFirstChild("HumanoidRootPart")
                            if h then
                                fastQuestBrought[m] = h.Position -- track NPC position for escape detection
                                pcall(function() hrp.CFrame = auraGoal(h) end) -- snap player onto NPC
                            end
                        end
                    else
                        -- 2+ NPCs: bring them here, then FREEZE player at this exact spot
                        fastQuestFrozenPos = hrp.CFrame
                        for i, m in ipairs(questNPCs) do
                            if not fastQuestBrought[m] then
                                local h = m:FindFirstChild("HumanoidRootPart")
                                if h then
                                    local angle = (i / math.max(#questNPCs, 1)) * math.pi * 2
                                    local tx = hrp.Position.X + math.cos(angle) * BRING_OFFSET
                                    local tz = hrp.Position.Z + math.sin(angle) * BRING_OFFSET
                                    local boughtPos = Vector3.new(tx, h.Position.Y, tz)
                                    fastQuestBrought[m] = boughtPos -- store for escape detection
                                    pcall(function() h.CFrame = CFrame.new(boughtPos) end)
                                end
                            end
                        end
                    end
                end
            end
        else
            questNPCs = {}
            fastQuestFrozenPos = nil -- NPCs all dead; unfreeze player for next wave
        end
        task.wait(0.03) -- fast retarget: teleport chases the next mob almost instantly
    end
end)

