-- NOCLIP: active ONLY while a movement feature (Kill Aura / Auto Quest / Reach & Kill) is on.
-- Stores each part's ORIGINAL CanCollide and restores it the moment you turn everything off,
-- so noclip no longer stays stuck on after you disable the features.
local noclipCache, noclipModel = {}, nil
local noclipActive = false
CONNS[#CONNS+1] = RunService.Stepped:Connect(function()
    if getgenv().NexoHubSession ~= SESSION then return end
    local shouldNoclip = KillOn or QuestOn or ReachOn
    if not shouldNoclip then
        -- everything off: restore original collision ONCE, then stop noclipping
        if noclipActive then
            for _, e in ipairs(noclipCache) do
                if e.part and e.part.Parent then pcall(function() e.part.CanCollide = e.orig end) end
            end
            noclipActive = false
        end
        return
    end
    local mdl = getModel()
    if not mdl then noclipCache = {} noclipModel = nil noclipActive = false return end
    if mdl ~= noclipModel then -- rebuild cache only when character changes
        noclipModel = mdl
        noclipCache = {}
        for _, p in ipairs(mdl:GetDescendants()) do
            if p:IsA("BasePart") then table.insert(noclipCache, { part = p, orig = p.CanCollide }) end
        end
    end
    for _, e in ipairs(noclipCache) do
        if e.part and e.part.Parent then e.part.CanCollide = false end
    end
    noclipActive = true
end)

