-- Goto LumenConverter: locate that specific NPC, then smoothly tween the player to it
local function findLumen()
    local target = "lumenconverter"
    -- 1) direct model-name match in the server folders
    for _, folder in ipairs({NPCsF, PlayersF}) do
        if folder then
            for _, m in ipairs(folder:GetChildren()) do
                if string.lower(m.Name) == target then
                    local h = m:FindFirstChild("HumanoidRootPart")
                    if h then return h.Position end
                end
            end
        end
    end
    -- 2) client rig name-tag match (names live on client rigs, not server models)
    local ClientF = workspace.Characters:FindFirstChild("Client")
    if ClientF then
        for _, d in ipairs(ClientF:GetDescendants()) do
            if d:IsA("TextLabel") and string.find(string.lower(d.Text), target, 1, true) then
                local rig = d:FindFirstAncestorWhichIsA("Model")
                local h = rig and rig:FindFirstChild("HumanoidRootPart")
                if h then return h.Position end
            end
        end
    end
    -- 3) fallback: any model named LumenConverter anywhere in workspace
    for _, m in ipairs(workspace:GetDescendants()) do
        if m:IsA("Model") and string.lower(m.Name) == target then
            local h = m:FindFirstChild("HumanoidRootPart")
            if h then return h.Position end
        end
    end
    return nil
end

local function tweenToLumen()
    local mdl = getModel()
    local hrp = mdl and mdl:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local pos = findLumen()
    if not pos then return false end
    -- instant teleport straight to the NPC (no tween)
    pcall(function()
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
    end)
    return true
end

