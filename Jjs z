        return
    end
    -- Fast Quest + multiple NPCs: hold player frozen where the bring happened
    if FastQuestOn and fastQuestFrozenPos and #questNPCs > 1 then
        pcall(function()
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.CFrame = fastQuestFrozenPos
        end)
        questHoverPos = fastQuestFrozenPos
        return
    end
    -- Normal Auto Quest: lerp smoothly toward the nearest quest NPC
    local nearest, nd
    for _, m in ipairs(questNPCs) do
        local h = m:FindFirstChild("HumanoidRootPart")
        if h then
            local d = (h.Position - hrp.Position).Magnitude
            if not nd or d < nd then nearest, nd = h, d end
        end
    end
    if nearest then
        local goal = auraGoal(nearest)
        pcall(function()
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.CFrame = goal -- instant teleport (no tween)
        end)
        questHoverPos = hrp.CFrame -- save every frame for hover when NPCs die
    end
end)

