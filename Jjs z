-- computes WHERE YOU STAND relative to the target NPC (Top / Front / Bottom + X/Y/Z offset)
local function auraGoal(nh)
    local base = nh.Position
    local off
    if AURA_MODE == "Top" then
        off = Vector3.new(0, STICK_OFFSET, 0)
    elseif AURA_MODE == "Bottom" then
        off = Vector3.new(0, -STICK_OFFSET, 0)
    else -- Front
        off = nh.CFrame.LookVector * STICK_OFFSET
    end
    local pos = base + off + Vector3.new(OX, OY, OZ)
    -- STABLE orientation: look at the NPC only on the horizontal plane.
    -- (CFrame.new(pos, base) spins/shakes when pos is directly above or below base.)
    local flat = Vector3.new(base.X, pos.Y, base.Z)
    if (flat - pos).Magnitude < 0.1 then
        return CFrame.new(pos)
    end
    return CFrame.new(pos, flat)
end

